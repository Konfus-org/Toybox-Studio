<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.HandlePickerPropertyView"
             x:DataType="local:HandlePickerPropertyViewModel">
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <Border Classes="fieldHost">
            <DockPanel>
                <!-- Picker: opens the asset chooser filtered to this handle's type. The icon needs an
                     explicit foreground — an IconView with no colour leaves its glyph unpainted. -->
                <Button DockPanel.Dock="Right" Classes="fieldButton" Command="{Binding PickCommand}"
                        VerticalAlignment="Stretch" ToolTip.Tip="Pick from asset database">
                    <local:IconView Width="14" Height="14" IconName="Target"
                                    Foreground="{DynamicResource ThemeTextBrush}"/>
                </Button>
                <!-- Current reference as a hyperlink: a set reference reveals it in the catalog; "None" opens
                     the asset chooser to pick one. -->
                <Button Command="{Binding ActivateCommand}" Cursor="Hand"
                        HorizontalAlignment="Left" HorizontalContentAlignment="Left" Margin="7,0,0,0"
                        Padding="0" Background="Transparent" BorderThickness="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}" FontSize="12"
                               Foreground="{DynamicResource SystemAccentColor}" TextDecorations="Underline"/>
                </Button>
            </DockPanel>
        </Border>
    </local:PropertyRow>
</UserControl>
