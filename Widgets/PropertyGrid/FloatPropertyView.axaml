<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.FloatPropertyView"
             x:DataType="local:FloatPropertyViewModel">
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <NumericUpDown Classes="field" ShowButtonSpinner="False" FormatString="0.######" Increment="0.1"
                       Value="{Binding Value}" IsEnabled="{Binding !IsReadOnly}"/>
    </local:PropertyRow>
</UserControl>
