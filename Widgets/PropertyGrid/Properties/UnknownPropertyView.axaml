<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.UnknownPropertyView"
             x:DataType="local:UnknownPropertyViewModel">
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <SelectableTextBlock Text="{Binding Json}" TextWrapping="Wrap" FontSize="12"
                             FontFamily="{DynamicResource ThemeMonoFontFamily}" Opacity="0.7"/>
    </local:PropertyRow>
</UserControl>
