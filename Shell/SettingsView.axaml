<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="using:Toybox.Studio.Shell"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Shell.SettingsView"
             x:DataType="shell:SettingsViewModel">

    <TabControl Margin="8">
        <TabItem Header="Editor">
            <Grid RowDefinitions="*,Auto" Margin="8">
                <pg:PropertyGridView Grid.Row="0" Items="{Binding EditorSettingsProperties}"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                    <Button Content="Create Theme…" Command="{Binding CreateThemeCommand}"/>
                    <Button Content="Open Themes Folder" Command="{Binding OpenThemesFolderCommand}"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="Project">
            <Grid RowDefinitions="Auto,*" Margin="8">
                <TextBlock Grid.Row="0" Text="Open a project to edit its settings."
                           IsVisible="{Binding !HasProject}" Opacity="0.6"/>
                <pg:PropertyGridView Grid.Row="1" Items="{Binding ProjectSettingsProperties}"
                                     IsVisible="{Binding HasProject}"/>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
