<Window xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 x:Class="Toybox.Studio.Shell.MessageBoxWindow"
                 Width="440" SizeToContent="Height" CanResize="False"
                 WindowStartupLocation="CenterOwner"
                 Title="Toybox Studio">

    <StackPanel Margin="20" Spacing="16">
        <TextBlock Name="MessageText" TextWrapping="Wrap"/>
        <Button Classes="Flat" Content="OK" HorizontalAlignment="Right" MinWidth="80"
                Click="OnOkClick"/>
    </StackPanel>
</Window>
