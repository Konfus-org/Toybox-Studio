{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 3
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_CXX_SCAN_FOR_MODULES": "OFF",
                "CMAKE_UNITY_BUILD": "OFF",
                "TBX_ENABLE_COMPILER_CACHE": "ON"
            }
        },
        {
            "name": "msvc",
            "displayName": "MSVC (Visual Studio)",
            "description": "MSVC via CMake's default Visual Studio generator, which locates the toolchain itself (no developer command prompt required).",
            "inherits": "base",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            }
        },
        {
            "name": "clang",
            "displayName": "Clang (Ninja)",
            "description": "Clang via Ninja Multi-Config; clang/clang++ and ninja must be on PATH.",
            "inherits": "base",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc-debug",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "msvc-release",
            "configurePreset": "msvc",
            "configuration": "Release"
        },
        {
            "name": "clang-debug",
            "configurePreset": "clang",
            "configuration": "Debug"
        },
        {
            "name": "clang-release",
            "configurePreset": "clang",
            "configuration": "Release"
        }
    ]
}
