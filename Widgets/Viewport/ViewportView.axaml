<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.Viewport"
             xmlns:ghost="using:Toybox.Studio.Widgets.Ghost"
             x:Class="Toybox.Studio.Widgets.Viewport.ViewportView"
             x:DataType="local:ViewportViewModel">

    <!-- ViewportInput captures pointer/keyboard while focused and forwards it to the engine view
         (editor fly camera). Background must be non-null so the Panel receives pointer events. The cursor
         hides while the game requests relative (mouselook) mode; the input behavior re-centres it. -->
    <Panel x:Name="Surface" Background="Transparent" Focusable="True" local:ViewportInput.Enabled="True">
        <!-- The cursor hides only while the game wants mouselook AND this panel is focused, so Alt+Esc
             (which drops focus) hands the cursor back even though the game still requests relative mode. -->
        <Panel.Cursor>
            <MultiBinding Converter="{x:Static local:RelativeMouseCursorConverter.Instance}">
                <Binding Path="RelativeMouse"/>
                <Binding Path="IsFocused" ElementName="Surface"/>
            </MultiBinding>
        </Panel.Cursor>
        <!-- Samples the engine view's shared GPU texture directly (zero copy). Reports back to the
             view-model if this compositor can't import it, so the ghost shows instead of black. -->
        <local:CompositionInteropViewport
            Surface="{Binding CurrentSurface}"
            InteropUnavailable="{Binding InteropUnavailable, Mode=OneWayToSource}"/>

        <ghost:GhostView Message="No world loaded." IsVisible="{Binding ShowEmptyGhost}"/>

        <!-- Loading blocks only the viewport; the rest of the editor stays interactive. -->
        <Border Background="{DynamicResource ThemeScrimBrush}" IsVisible="{Binding ShowLoadingGhost}">
            <ghost:LoadingGhostView Message="{Binding LoadingMessage}"/>
        </Border>
    </Panel>
</UserControl>
