<Window xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:shell="using:Toybox.Studio.Shell"
                 xmlns:status="using:Toybox.Studio.Widgets.Status"
                 xmlns:workspace="using:Toybox.Studio.Workspace"
                 xmlns:dock="using:Dock.Avalonia.Controls"
                 xmlns:dockModel="using:Dock.Model.Avalonia.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="850"
                 x:Class="Toybox.Studio.Shell.MainWindow"
                 x:Name="RootWindow"
                 x:DataType="shell:ShellViewModel"
                 Icon="/Assets/Icons/Toybox.png"
                 Title="{Binding Title}"
                 Width="1440" Height="850">

    <DockPanel>
        <Panel DockPanel.Dock="Top" Margin="8,2">
            <Menu HorizontalAlignment="Left" VerticalAlignment="Center">
                <MenuItem Header="File">
                    <MenuItem Header="Open Project…" Command="{Binding OpenProjectCommand}"/>
                </MenuItem>
                <MenuItem Header="Build">
                    <MenuItem Header="Compile" Command="{Binding CompileCommand}"/>
                    <Separator/>
                    <MenuItem Header="Ship">
                        <MenuItem Header="Debug" Command="{Binding ShipCommand}" CommandParameter="Debug"/>
                        <MenuItem Header="Release" Command="{Binding ShipCommand}" CommandParameter="Release"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Debug">
                    <MenuItem Header="Avalonia Dev Tools" Command="{Binding DebugEditorCommand}"/>
                    <MenuItem Header="Attach to Running Instance" Command="{Binding AttachCommand}"/>
                </MenuItem>
                <!-- Data-driven: one item per registered [Dockable], opened (or focused) by Id. -->
                <MenuItem Header="Windows" ItemsSource="{Binding Workspace.All}">
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem" x:DataType="workspace:DockableDescriptor"
                                      BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding Title}"/>
                            <Setter Property="Command"
                                    Value="{Binding #RootWindow.((shell:ShellViewModel)DataContext).Workspace.OpenDockableCommand}"/>
                            <Setter Property="CommandParameter" Value="{Binding Id}"/>
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
                <MenuItem Header="Layout">
                    <MenuItem Header="Reset Layout" Command="{Binding Workspace.ResetLayoutCommand}"/>
                </MenuItem>
            </Menu>
            <!-- The Play/Stop/Pause transport now lives on the Game view, not the title bar. -->
        </Panel>

        <Border Classes="StatusBar" DockPanel.Dock="Bottom">
            <status:StatusView DataContext="{Binding Status}"/>
        </Border>

        <!-- Factory + the real (saved or default) layout are assigned in code from Workspace; the layout is
             data-driven, saved on exit. The inline empty RootDock is just a placeholder so the dock chrome
             has a non-null Layout to bind against during construction (otherwise Layout.* binds log errors
             before Workspace.Bind runs); it's replaced the moment the shell DataContext arrives. -->
        <dock:DockControl x:Name="DockHost" Margin="6">
            <dock:DockControl.Layout>
                <dockModel:RootDock/>
            </dock:DockControl.Layout>
        </dock:DockControl>
    </DockPanel>
</Window>
