<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:util="using:Toybox.Studio.Widgets.Behaviors"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.ArrayPropertyView"
             x:DataType="local:ArrayPropertyViewModel">
    <StackPanel IsVisible="{Binding Visible}">
        <!-- A ROOT-level list renders as the accent section band. The trailing parts read right-to-left like a
             leaf row — state dot at the far-right edge, then the chevron — so the summary ("N items") and the
             append (+) button float flush against the chevron with no empty gap before it. Absent parts (the +
             on a fixed list) collapse to zero width, and the + button swallows its own click so adding never
             collapses the section. -->
        <ToggleButton Classes="sectionHeader" IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                      IsVisible="{Binding !IsNested}"
                      Background="{Binding Depth, Converter={x:Static local:DepthToBrushConverter.Instance}}">
            <DockPanel Margin="{Binding Depth, Converter={x:Static local:DepthToIndentConverter.Instance}}">
                <!-- A root list shows its default-state indicator (and reset), like a row — pinned to the edge.
                     A ContentControl (not a bare ContentPresenter) so the StateIndicatorPart's implicit
                     DataTemplate resolves: a bare presenter outside a control template has no TemplatedParent
                     and renders nothing. -->
                <ContentControl DockPanel.Dock="Right" Content="{Binding StateIndicator}"
                                VerticalAlignment="Center"/>
                <!-- Disclosure chevron on the LEFT, before the icon/label, like a tree node. -->
                <Path DockPanel.Dock="Left" Classes="sectionChevron" Width="8" Height="8" Stretch="Uniform"
                      Margin="2,0,8,0" VerticalAlignment="Center" Data="M 0,0 L 8,4 L 0,8 Z"/>
                <Button DockPanel.Dock="Right" Classes="fieldButton" Command="{Binding AddCommand}"
                        IsVisible="{Binding IsResizable}" ToolTip.Tip="Add entry">
                    <local:IconView Width="13" Height="13" IconName="Plus"
                                    Foreground="{DynamicResource ThemeSuccessBrush}"/>
                </Button>
                <TextBlock DockPanel.Dock="Right" Text="{Binding Summary}" FontSize="12"
                           Foreground="{DynamicResource ThemeMutedTextBrush}"
                           VerticalAlignment="Center" Margin="8,0"/>
                <local:IconView DockPanel.Dock="Left" Width="15" Height="15" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
                <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"
                           ToolTip.Tip="{Binding Description}"/>
            </DockPanel>
        </ToggleButton>

        <!-- A NESTED list renders as an ordinary property row, toggling on a tap anywhere; the summary sits in
             the value area while the add (+) button, the disclosure chevron and the state indicator render in
             the row's own Actions / Dropdown / State slots (from the list's parts). -->
        <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                           Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}"
                           IconName="{Binding Icon}" IconColor="{Binding IconColor}"
                           IsVisible="{Binding IsNested}"
                           util:ExpandNod.State="{Binding IsExpanded}"
                           util:ToggleOnTap.Enabled="True"
                           util:ToggleOnTap.State="{Binding IsExpanded, Mode=TwoWay}">
            <TextBlock Text="{Binding Summary}" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeMutedTextBrush}"/>
        </local:PropertyRow>

        <!-- Each entry is just its own row; the reorder grip and the delete (x) are parts on the element row
             itself (its Handle / Actions slots), attached by ArrayPropertyViewModel.Rebuild. -->
        <ItemsControl ItemsSource="{Binding Items}" IsVisible="{Binding IsExpanded}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:PropertyViewModel">
                    <ContentControl Content="{Binding}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
