<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Toybox.Studio.Widgets.Dialogs"
        xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
        x:Class="Toybox.Studio.Widgets.Dialogs.TextPromptDialog"
        x:DataType="local:TextPromptDialogViewModel"
        Icon="/Assets/Icons/Toybox.png"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Title="{Binding Title}">

    <StackPanel Margin="18" Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="14">
            <pg:IconView IconName="Pencil" IconColor="BLUE"
                         Width="30" Height="30" VerticalAlignment="Top"/>
            <TextBox Name="ValueBox" Text="{Binding Value}" PlaceholderText="{Binding Watermark}"
                     MinWidth="320" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="toy" Content="Cancel" MinWidth="80" IsCancel="True"
                    Command="{Binding CancelCommand}"/>
            <Button Classes="action" Content="{Binding ConfirmText}" MinWidth="80" IsDefault="True"
                    Command="{Binding ConfirmCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
