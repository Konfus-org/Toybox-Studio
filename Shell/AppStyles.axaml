<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="using:Dock.Avalonia.Controls">

    <!-- =================================================================================================
         THE Toybox Studio stylesheet — one place for all app styling/theming (think one CSS file). Sections:
           1. Design tokens   — theme "variables" (first-frame/design fallbacks; ThemeManager overwrites
                                 them live from the active Theme.json at runtime).
           2. Packaged themes — control themes we depend on (ColorPicker, Dock). Loaded after FluentTheme,
                                 which is applied in App.axaml.
           3. Styles          — window, status bar, section headers.
         ================================================================================================= -->

    <!-- 1. DESIGN TOKENS ============================================================================== -->
    <!-- First-frame/design-time fallbacks, seeded from the Claymorphism base theme. At runtime ThemeManager
         overwrites these from the active Theme.json — including replacing the flat brand/neutral brushes with
         LinearGradientBrushes where the theme defines gradients. -->
    <Styles.Resources>
        <!-- Seed COLOURS that the derived neutral brushes below key off. ThemeApplier overwrites these live
             from the active Theme.json — the text / on-colour / muted ones are its WCAG auto-contrast results,
             the rest are representative palette colours. The brushes that derive from them follow
             automatically via DynamicResource, so the derivation reads in one declarative place. -->
        <Color x:Key="ThemeTextColor">#4A4036</Color>
        <Color x:Key="ThemeOnColorColor">#FFFFFF</Color>
        <Color x:Key="ThemeMutedColor">#8A8073</Color>
        <Color x:Key="ThemeBackgroundColor">#EFE6D4</Color>
        <Color x:Key="ThemeSurfaceColor">#F7F0E2</Color>
        <Color x:Key="ThemePrimaryColor">#9888EB</Color>

        <!-- Brand / neutral FILLS — ThemeApplier replaces these with LinearGradientBrushes where the theme
             defines gradients; these are the flat first-frame fallbacks. -->
        <SolidColorBrush x:Key="ThemePrimaryBrush" Color="#A99BF0"/>
        <SolidColorBrush x:Key="ThemeSecondaryBrush" Color="#C7B8A6"/>
        <SolidColorBrush x:Key="ThemeTertiaryBrush" Color="#A9E5C5"/>
        <SolidColorBrush x:Key="ThemeErrorBrush" Color="#E08379"/>
        <SolidColorBrush x:Key="ThemeWarningBrush" Color="#F2C879"/>
        <SolidColorBrush x:Key="ThemeInfoBrush" Color="#86C5E8"/>
        <SolidColorBrush x:Key="ThemeSuccessBrush" Color="#8FD9AE"/>
        <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#EFE6D4"/>
        <SolidColorBrush x:Key="ThemeSurfaceBrush" Color="#F7F0E2"/>

        <!-- Neutral INKS + TINTS derived from the seed colours above. ThemeApplier no longer writes these —
             it publishes the colours and these brushes track them live via DynamicResource. Opacity is the
             former 8-bit alpha as a fraction (e.g. 0x2E/0xFF ≈ 0.18, 0x59/0xFF ≈ 0.349). -->
        <SolidColorBrush x:Key="ThemeTextBrush" Color="{DynamicResource ThemeTextColor}"/>
        <SolidColorBrush x:Key="ThemeOnColorTextBrush" Color="{DynamicResource ThemeOnColorColor}"/>
        <SolidColorBrush x:Key="ThemeMutedTextBrush" Color="{DynamicResource ThemeMutedColor}"/>
        <SolidColorBrush x:Key="ThemeDisabledTextBrush" Color="{DynamicResource ThemeTextColor}" Opacity="0.349"/>
        <SolidColorBrush x:Key="ThemeAccentSolidBrush" Color="{DynamicResource ThemePrimaryColor}"/>
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="{DynamicResource ThemeTextColor}" Opacity="0.18"/>
        <SolidColorBrush x:Key="ThemeHeaderBrush" Color="{DynamicResource ThemeTextColor}" Opacity="0.094"/>
        <SolidColorBrush x:Key="ThemeBandBrush" Color="{DynamicResource ThemeTextColor}" Opacity="0.063"/>
        <SolidColorBrush x:Key="ThemeWellBrush" Color="{DynamicResource ThemeTextColor}" Opacity="0.039"/>
        <SolidColorBrush x:Key="ThemeGrooveBrush" Color="{DynamicResource ThemeTextColor}" Opacity="0.078"/>
        <SolidColorBrush x:Key="ThemeHeaderRaisedBrush" Color="{DynamicResource ThemeTextColor}" Opacity="0.071"/>
        <SolidColorBrush x:Key="ThemeScrimBrush" Color="{DynamicResource ThemeBackgroundColor}" Opacity="0.69"/>
        <SolidColorBrush x:Key="ThemeMenuHighlightBrush" Color="{DynamicResource ThemePrimaryColor}" Opacity="0.227"/>
        <SolidColorBrush x:Key="ThemeSurfaceFlatBrush" Color="{DynamicResource ThemeSurfaceColor}"/>

        <!-- C#-owned fills kept here only as first-frame fallbacks (ThemeApplier overwrites them live).
             ThemeWellInsetShadow / ThemeCardShadow are BoxShadows built in code, so they have no XAML
             fallback — until ThemeApplier runs an input simply shows no inset, which is harmless. -->
        <SolidColorBrush x:Key="ThemeWellFillBrush" Color="#F0E2CB"/>
        <SolidColorBrush x:Key="ThemeRowBrush" Color="#FBF6EC"/>
        <SolidColorBrush x:Key="ThemeAccentBrightBrush" Color="#C9BCF5"/>
        <!-- Kill Fluent's selected-tab underline pipe at the source: the template paints it with this brush,
             so a transparent fill removes the underline even when Fluent re-shows the pipe via its :selected
             trigger (which can outrank a plain IsVisible override). The filled accent pill marks selection. -->
        <SolidColorBrush x:Key="TabItemHeaderSelectedPipeFill" Color="Transparent"/>
        <CornerRadius x:Key="ThemeTabCornerRadius">14,14,0,0</CornerRadius>
        <CornerRadius x:Key="ThemePanelCornerRadius">0</CornerRadius>
        <!-- Right-edge-only rounding (TR + BR), used by the numeric field's rightmost decrease chevron.
             ThemeManager overwrites this live from theme.CornerRadius; this is the first-frame fallback. -->
        <CornerRadius x:Key="ThemeRightCornerRadius">0,7,7,0</CornerRadius>
        <!-- Panel drop shadow; ThemeManager recomputes direction/opacity from the theme's shadow settings. -->
        <DropShadowEffect x:Key="ThemePanelShadowEffect" Color="#3A000000" BlurRadius="18" OffsetX="4" OffsetY="4"/>
        <FontFamily x:Key="ThemeFontFamily">Inter</FontFamily>
        <FontFamily x:Key="ThemeMonoFontFamily">Cascadia Mono, Consolas, monospace</FontFamily>
        <x:Double x:Key="ThemeFontSize">13</x:Double>

        <!-- Flat, hover-less Button theme for the pinned-tool tab's inner toggle (see the ToolPinItemControl
             styles below). Avalonia's default Fluent Button re-tints its own ContentPresenter white on
             pointerover/press via its private resources — not via the Button Background — and that
             ContentPresenter sits one template level too deep to reach from a ToolPinItemControl selector.
             Swapping the Button's Theme for this transparent one removes that stray tint so only the
             ToolPinItemControl's own wash / purple pill shows. -->
        <ControlTheme x:Key="PinTabButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Background="Transparent"/>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Styles.Resources>

    <!-- 2. PACKAGED CONTROL THEMES ==================================================================== -->
    <!-- ColorPicker/ColorView templates ship in their own package and are NOT bundled with FluentTheme;
         without this include the ColorPicker control has no template (e.g. the Theme Creator's pickers). -->
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>
    <StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml"/>

    <!-- 3. STYLES ==================================================================================== -->
    <!-- Apply the theme font, background, and text colour to every window. Foreground is inherited, so
         raw TextBlocks pick up the theme's Text colour unless they opt out. -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource ThemeFontSize}"/>
        <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
    </Style>

    <Style Selector="Border.StatusBar">
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ThemeHeaderBrush}"/>
    </Style>

    <!-- Section header style. -->
    <Style Selector="TextBlock.h4">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- 4. DOCK DROP-TARGET SELECTORS ================================================================
         Dock's drag drop-target squares are baked white PNGs. ThemeManager multiply-tints them to the
         primary accent at runtime into these DynamicResource keys; here we point each selector Image
         (DockTarget + GlobalDockTarget) at the recoloured bitmap, overriding Dock's hardcoded Source. -->
    <Style Selector="dock|DockTarget /template/ Image#PART_TopSelector, dock|GlobalDockTarget /template/ Image#PART_TopSelector">
        <Setter Property="Source" Value="{DynamicResource DockSelectorTopImage}"/>
    </Style>
    <Style Selector="dock|DockTarget /template/ Image#PART_BottomSelector, dock|GlobalDockTarget /template/ Image#PART_BottomSelector">
        <Setter Property="Source" Value="{DynamicResource DockSelectorBottomImage}"/>
    </Style>
    <Style Selector="dock|DockTarget /template/ Image#PART_LeftSelector, dock|GlobalDockTarget /template/ Image#PART_LeftSelector">
        <Setter Property="Source" Value="{DynamicResource DockSelectorLeftImage}"/>
    </Style>
    <Style Selector="dock|DockTarget /template/ Image#PART_RightSelector, dock|GlobalDockTarget /template/ Image#PART_RightSelector">
        <Setter Property="Source" Value="{DynamicResource DockSelectorRightImage}"/>
    </Style>
    <Style Selector="dock|DockTarget /template/ Image#PART_CenterSelector, dock|GlobalDockTarget /template/ Image#PART_CenterSelector">
        <Setter Property="Source" Value="{DynamicResource DockSelectorInsideImage}"/>
    </Style>

    <!-- 5. CLAYMORPHISM ============================================================================== -->
    <!-- Soft, puffy clay chrome. The KEY to shape-correct shadows: put the shadow as a BoxShadow on the exact
         rounded template border the control draws (PART_BorderElement / PART_ContentPresenter / Background),
         NOT a DropShadowEffect on the whole control — an Effect shadows the control's full rectangular bounds
         and so doesn't follow the rounded pill. Surface gradients come from ThemeManager (it routes the
         theme's Surface gradient onto FluentTheme's control-background keys). -->

    <!-- Each docked panel is a SQUARE card (square title bar, square corners), inset by a small margin so the
         window's radial background shows between cards. Its DropShadowEffect comes from the theme. -->
    <Style Selector="dock|ToolChromeControl">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Effect" Value="{DynamicResource ThemePanelShadowEffect}"/>
    </Style>
    <!-- Panel header gradient + outline removal are done by overriding the REAL Dock brush keys in
         ThemeManager (DockSurfaceHeaderActiveBrush for the active Grid#PART_Grip; DockBorderSubtle/Strong for
         Border#PART_Border) — so no template-part guessing here. -->
    <Style Selector="dock|ToolChromeControl /template/ Border">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <!-- The panel's content border (PART_Border wraps the header AND the content) is square and CLIPS its
         content, so a panel whose content is a square opaque surface (the viewport texture) stays inside the
         border instead of painting over it — letting the focus outline ring the WHOLE panel, not just the
         title bar. The drop shadow still renders: it's an Effect on the control (ClipToBounds=False), not on
         this inner border. -->
    <Style Selector="dock|ToolChromeControl /template/ Border#PART_Border">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>
    <!-- The focused (active) docked panel gets a square primary-accent border ringing the entire panel. -->
    <Style Selector="dock|ToolChromeControl:active /template/ Border#PART_Border">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentSolidBrush}"/>
    </Style>

    <!-- BUTTON SYSTEM — every button shares the SAME top→bottom gradient shading (from ButtonBackground in
         ThemeManager, whose PointerOver brush is just a brighter copy) and carries NO shadow. Standard buttons
         brighten on hover via that resource. The semantic classes only swap the colour and must override the
         PRESENTER background in every state (Fluent sets hover/press on the presenter directly, which would
         otherwise beat a plain Button.Background and revert the colour — that was the "hover changes" bug):
           • .action — primary brand colour    • .play — success/green    • .stop — error/red
         Hover BRIGHTENS the current colour (a lighter gradient of the same hue) rather than changing it. -->
    <Style Selector="Button.action, Button.play, Button.stop">
        <Setter Property="Foreground" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>
    <Style Selector="Button.action /template/ ContentPresenter#PART_ContentPresenter, Button.action:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeActionButtonBrush}"/>
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeActionButtonHoverBrush}"/>
    </Style>
    <Style Selector="Button.play /template/ ContentPresenter#PART_ContentPresenter, Button.play:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemePlayButtonBrush}"/>
    </Style>
    <Style Selector="Button.play:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemePlayButtonHoverBrush}"/>
    </Style>
    <Style Selector="Button.stop /template/ ContentPresenter#PART_ContentPresenter, Button.stop:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeStopButtonBrush}"/>
    </Style>
    <Style Selector="Button.stop:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeStopButtonHoverBrush}"/>
    </Style>

    <!-- Clay "popout" buttons (the console's Clear, the Game transport): the SAME soft surface gradient,
         hairline border and rounding as the search pills — so a button reads as a raised clay surface — and
         they DIM on hover/press (like the chrome-less buttons) instead of brightening or flipping their icon
         to a dark ink. Icon colour is left to the button's content (e.g. a green play / red stop glyph), and
         since that's a local value it survives hover rather than going black. -->
    <Style Selector="Button.clay, ToggleButton.clay">
        <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
        <Setter Property="Padding" Value="12,5"/>
    </Style>
    <Style Selector="Button.clay /template/ ContentPresenter#PART_ContentPresenter,
                     Button.clay:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                     Button.clay:pressed /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.clay /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.clay:checked /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.clay:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.clay:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
    </Style>
    <Style Selector="Button.clay:pointerover, ToggleButton.clay:pointerover">
        <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <Style Selector="Button.clay:pressed, ToggleButton.clay:pressed, ToggleButton.clay:checked">
        <Setter Property="Opacity" Value="0.65"/>
    </Style>

    <!-- Consistent disabled look for EVERY button (so the Game transport and the World add/refresh match):
         the theme's muted fill + ink, no shadow. -->
    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeDisabledBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeDisabledTextBrush}"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
    </Style>
    <!-- Icon-only buttons (Basic): just the glyph — no fill and no hover background. Slightly dimmed at rest,
         brightening on hover (and dimmer still when disabled, below), exactly like the list "+" affordances.
         The presenter background is forced transparent in every interaction state so neither Fluent's hover
         fill nor the standard button gradient shows through. -->
    <Style Selector="Button.Basic">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>
    <Style Selector="Button.Basic:pointerover">
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.Basic /template/ ContentPresenter#PART_ContentPresenter,
                     Button.Basic:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                     Button.Basic:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- Chrome-less icon buttons (Basic / row affordances) just dim when disabled — no fill. -->
    <Style Selector="Button.Basic:disabled /template/ ContentPresenter#PART_ContentPresenter, Button.rowButton:disabled /template/ ContentPresenter#PART_ContentPresenter, Button.fieldButton:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.Basic:disabled">
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- A continuous rotation for "busy" affordances — add Classes="spin" (typically bound to a command's
         IsRunning) to a refresh icon and it turns while the work is in flight. -->
    <Style Selector="PathIcon.spin">
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" Easing="LinearEasing">
                <KeyFrame Cue="0%">
                    <Setter Property="RotateTransform.Angle" Value="0"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="RotateTransform.Angle" Value="360"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Dock panel-chrome buttons (pin / menu / close in a title bar, and a tab's close button) are icon
         buttons. They carry no class, so they get NO shadow; a single /template/ hop flattens their fill to
         transparent (Fluent binds the presenter background to Button.Background). A faint band shows on hover. -->
    <Style Selector="dock|ToolChromeControl /template/ Button, dock|ToolTabStripItem /template/ Button, dock|DocumentTabStripItem /template/ Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="7"/>
    </Style>
    <Style Selector="dock|ToolChromeControl /template/ Button:pointerover, dock|ToolTabStripItem /template/ Button:pointerover, dock|DocumentTabStripItem /template/ Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource ThemeBandBrush}"/>
    </Style>
    <!-- When a panel is FOCUSED its header fills with the primary gradient; Dock's active state otherwise
         tints the pin/menu/close glyphs the accent colour (≈ the header colour → invisible). Force them to
         the on-colour ink so they read on the coloured header. -->
    <Style Selector="dock|ToolChromeControl:active /template/ Path">
        <Setter Property="Fill" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>
    <!-- …and the title text on the focused (primary-filled) header goes on-primary so it isn't dark-on-dark. -->
    <Style Selector="dock|ToolChromeControl:active /template/ TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>

    <!-- DROPDOWN / MENU CLAY: the popup is rounded (OverlayCornerRadius) with a soft drop shadow, and each
         item's highlight (Fluent's square, edge-flush Border#PART_LayoutRoot) is rounded to the theme radius +
         inset so it never pokes past the dropdown's rounded corners. -->
    <Style Selector="MenuItem /template/ Border#PART_LayoutRoot, MenuFlyoutPresenter MenuItem /template/ Border#PART_LayoutRoot">
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
        <Setter Property="Margin" Value="4,1"/>
    </Style>
    <!-- …and that highlight uses the PRIMARY colour (a translucent tint) on hover / open / press, not grey. -->
    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot,
                     MenuItem:selected /template/ Border#PART_LayoutRoot,
                     MenuItem:pressed /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}"/>
    </Style>
    <Style Selector="MenuFlyoutPresenter /template/ Border#LayoutRoot, MenuFlyoutPresenter /template/ Border, ContextMenu /template/ Border">
        <Setter Property="CornerRadius" Value="{DynamicResource OverlayCornerRadius}"/>
        <Setter Property="BoxShadow" Value="0 6 18 0 #33000000"/>
    </Style>
    <!-- ComboBox dropdown items: same rounded, inset hover so it stays within the rounded popup. -->
    <Style Selector="ComboBoxItem">
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Margin" Value="3,1"/>
    </Style>

    <!-- Inputs read as PRESSED clay wells: a recessed fill (routed onto the FluentTheme surface keys in
         ThemeManager) plus an inset BoxShadow on the exact rounded template border, so text boxes, numeric
         fields (their inner PART_TextBox is a TextBox, so this catches them too), combo boxes and the search
         box all look moulded into the surface. The shadow rides the real border element, so it follows the
         control's corner radius. -->
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="BoxShadow" Value="{DynamicResource ThemeWellInsetShadow}"/>
    </Style>
    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="BoxShadow" Value="{DynamicResource ThemeWellInsetShadow}"/>
    </Style>

    <!-- Numeric fields are ONE clay well spanning the text and a pair of compact, flat up/down chevrons tucked
         at the right — the same slidable field used in the property grid (drag-to-scrub via NumericScrub) and
         in dialogs. The well + inset shadow live on the ButtonSpinner's own border so they wrap the whole
         control; the inner TextBox is stripped of its own border/inset so the two don't double up (this
         overrides the generic TextBox inset rule above, hence it comes after it). -->
    <Style Selector="ButtonSpinner /template/ Border#border">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
        <Setter Property="BoxShadow" Value="{DynamicResource ThemeWellInsetSoftShadow}"/>
    </Style>
    <Style Selector="NumericUpDown TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
    </Style>
    <Style Selector="NumericUpDown TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <!-- Flat clay spinner chevrons: borderless, compact, themed glyph, brightening on hover. -->
    <Style Selector="ButtonSpinner /template/ RepeatButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Width" Value="20"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>
    <Style Selector="ButtonSpinner /template/ RepeatButton:pointerover">
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <!-- The chevron's hover/press feedback is the opacity brighten above, NOT a fill. The Fluent
         RepeatButton template paints a square (un-rounded) background on its inner ContentPresenter when
         hovered/pressed; keep it transparent in every state so it can't poke out past the well's rounding. -->
    <Style Selector="ButtonSpinner /template/ RepeatButton /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ButtonSpinner /template/ RepeatButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ButtonSpinner /template/ RepeatButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <!-- The decrease chevron is the rightmost element of the spinner, so its top-right and bottom-right
         corners sit on the well's outer edge. Round them to the theme radius so the button hugs the well's
         curve instead of squaring it off (the left corners stay flat against the increase chevron). The
         inner ContentPresenter inherits this radius via TemplateBinding, but set it explicitly too so any
         future fill is clipped to the curve. -->
    <Style Selector="ButtonSpinner /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="CornerRadius" Value="{DynamicResource ThemeRightCornerRadius}"/>
    </Style>
    <Style Selector="ButtonSpinner /template/ RepeatButton#PART_DecreaseButton /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="CornerRadius" Value="{DynamicResource ThemeRightCornerRadius}"/>
    </Style>

    <!-- SHARED SECTION HEADER ======================================================================
         ONE collapsible section header used everywhere a run of properties is grouped: component sections
         (Inspector), category groups + nested object/array/theme parent rows (PropertyGrid), and script
         bindings (Scripts). A flat band (a subtle raised tint over the cohesive panel, no gradient, no
         shadow) with a groove beneath; the icon + label on the LEFT are tinted with the primary accent, and
         a disclosure chevron is pinned to the RIGHT. The WHOLE button is the toggle, so clicking anywhere on
         the band collapses/expands — no need to hit the tiny chevron. Interactive children inside the band
         (an enable checkbox, an add (+) button) swallow their own clicks, so they act without collapsing. -->
    <Style Selector="ToggleButton.sectionHeader">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeGrooveBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <!-- Foreground is pinned across every interaction state, because FluentTheme's ToggleButton:checked flips
         the foreground to its on-accent (white) ink — which, when a section is expanded, made the label and
         the "N items" summary unreadable on the light band. The combined selector keeps the accent (neutral
         for nested) in default/checked/pressed/pointerover alike. -->
    <Style Selector="ToggleButton.sectionHeader,
                     ToggleButton.sectionHeader:checked,
                     ToggleButton.sectionHeader:pressed,
                     ToggleButton.sectionHeader:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource ThemeAccentSolidBrush}"/>
    </Style>
    <Style Selector="ToggleButton.sectionHeader /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.sectionHeader:checked /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.sectionHeader:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeHeaderRaisedBrush}"/>
    </Style>
    <Style Selector="ToggleButton.sectionHeader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ThemeBandBrush}"/>
    </Style>
    <!-- The ContentPresenter's OWN foreground must be pinned, not just the button's: FluentTheme's :checked
         sets the presenter foreground to white, and the content label inherits from the presenter — so an
         expanded (checked) object/array header would otherwise show a white, unreadable label. -->
    <Style Selector="ToggleButton.sectionHeader /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.sectionHeader:checked /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.sectionHeader:pressed /template/ ContentPresenter#PART_ContentPresenter,
                     ToggleButton.sectionHeader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource ThemeAccentSolidBrush}"/>
    </Style>
    <!-- Chevron pinned right: points right when collapsed, rotates down when the section is expanded. Its
         fill follows the header's accent (overridden to neutral for nested sections, below). -->
    <Style Selector="ToggleButton.sectionHeader Path.sectionChevron">
        <Setter Property="Opacity" Value="0.6"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="Fill" Value="{DynamicResource ThemeAccentSolidBrush}"/>
    </Style>
    <Style Selector="ToggleButton.sectionHeader:checked Path.sectionChevron">
        <Setter Property="RenderTransform">
            <RotateTransform Angle="90"/>
        </Setter>
    </Style>

    <!-- Nested structs/arrays are NOT rendered as section bands at all: they render as ordinary property rows
         (PropertyRow), identical to their sibling leaf rows in gutter, depth tint and alignment, with a tap
         anywhere toggling them (ToggleOnTap). This is their right-hand disclosure chevron — a plain Path that
         rotates down when the row is expanded. Only categories and root-level structs keep the accent band. -->
    <Style Selector="Path.pgChevron">
        <Setter Property="Opacity" Value="0.7"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
    </Style>
    <Style Selector="Path.pgChevron.expanded">
        <Setter Property="RenderTransform">
            <RotateTransform Angle="90"/>
        </Setter>
    </Style>

    <!-- Folder-style tabs (Editor / Project, Components / Scripts / Json): the SELECTED tab is a filled
         accent pill with on-accent ink — a clearly visible background, no underline pipe — matching the
         purple selection language used by the docked tabs. Unselected tabs are chrome-less with muted ink
         and a faint hover band. Dock tabs are dock|ToolTabStripItem (a different type), untouched here. -->
    <Style Selector="TabControl">
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="TabControl /template/ ContentPresenter#PART_SelectedContentHost">
        <Setter Property="Background" Value="{DynamicResource ThemeSurfaceFlatBrush}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource ThemePanelCornerRadius}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>
    <Style Selector="TabItem">
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource ThemeTabCornerRadius}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}"/>
    </Style>
    <Style Selector="TabItem /template/ Border#PART_LayoutRoot">
        <Setter Property="CornerRadius" Value="{DynamicResource ThemeTabCornerRadius}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource ThemeBandBrush}"/>
    </Style>
    <!-- Selected tab is a filled accent pill with on-accent ink, so its background is clearly visible (not
         merged into the content surface) and no underline is needed. -->
    <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentSolidBrush}"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>
    <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>
    <Style Selector="TabItem:selected:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentSolidBrush}"/>
    </Style>
    <!-- Drop Fluent's selection underline pipe; the filled accent pill conveys selection instead. The
         :selected selector is essential: Fluent re-shows the pipe via a :selected pseudoclass trigger, which
         outranks a plain (non-activated) TabItem rule — so we must also match :selected to win on the
         selected tab (not just hide it on the unselected ones). -->
    <Style Selector="TabItem /template/ Border#PART_SelectedPipe,
                     TabItem:selected /template/ Border#PART_SelectedPipe,
                     TabItem:selected:pointerover /template/ Border#PART_SelectedPipe">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Flyouts / dropdowns / menus float, so they DO get a soft drop shadow (on the presenter border). -->
    <Style Selector="FlyoutPresenter /template/ Border, MenuFlyoutPresenter /template/ Border">
        <Setter Property="BoxShadow" Value="0 6 18 0 #33000000"/>
    </Style>

    <!-- The status strip reads as its own soft clay shelf (a Border we own → BoxShadow matches its corners). -->
    <Style Selector="Border.StatusBar">
        <Setter Property="BoxShadow" Value="0 -2 10 0 #24000000"/>
    </Style>

    <!-- The top toolbar bar: a clay shelf with the surface gradient + a soft lower shadow. -->
    <Style Selector="Border.Toolbar">
        <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="0,0,12,12"/>
        <Setter Property="BoxShadow" Value="0 3 12 0 #26000000"/>
    </Style>
    <!-- Top-level menu items read as soft clay pills, rounded to the theme radius. -->
    <Style Selector="Border.Toolbar Menu > MenuItem">
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="Margin" Value="2,0"/>
    </Style>

    <!-- Dock tabs: clay tabs with rounded tops, padding, a hover wash, and a raised selected tab. Tool and
         document tabs share the look. -->
    <Style Selector="dock|ToolTabStripItem, dock|DocumentTabStripItem">
        <Setter Property="CornerRadius" Value="10,10,0,0"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="Margin" Value="2,2,0,0"/>
    </Style>
    <Style Selector="dock|ToolTabStripItem:pointerover, dock|DocumentTabStripItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource DockTabHoverBackgroundBrush}"/>
    </Style>
    <!-- The SELECTED tab is always a purple (primary) pill with on-primary (white) text. Dock only fills it
         purple in :active:selected (window focused); the common :selected state would otherwise sit on the
         cream header colour. Force PART_TabBody purple for any :selected tab so it reads consistently. Note
         `:active` alone = "window focused" (every tab) — we key off `:selected`, the current tab. -->
    <!-- The SELECTED tab is always a purple (primary) pill with on-primary (white) text. Verified against
         Dock 12.0.0.2's DocumentTabStripItem.axaml: PART_TabBody binds {TemplateBinding Background} and the
         :selected states set the ITEM's Background. So we set the item Background directly (referencing OUR
         ThemePrimaryBrush) — this overrides Dock's :not(:active):selected / :active:selected states in both
         window-focused and unfocused cases, without fighting the template binding or Dock's resource scope. -->
    <Style Selector="dock|DocumentTabStripItem:selected, dock|ToolTabStripItem:selected">
        <!-- Flat purple (a tab is too small for the gradient to read). -->
        <Setter Property="Background" Value="{DynamicResource ThemeAccentSolidBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>
    <Style Selector="dock|DocumentTabStripItem:selected:pointerover, dock|ToolTabStripItem:selected:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>

    <!-- Pinned tool tabs (the collapsed auto-hide strip, e.g. "World") mirror the docked tabs above: the same
         muted tab-text colour, the same cream hover wash, and the same purple pill when focused. Dock's
         ToolPinItemControl is a transparent Border (binds the control Background) wrapping a Button + title
         TextBlock, so the wash / purple go on the control Background. The inner Button is swapped to a flat
         transparent Theme (PinTabButtonTheme) rather than just zeroing its Background: Fluent paints the
         hover/press tint on the button's ContentPresenter (one template level too deep for a ToolPinItemControl
         selector to reach), so only replacing the whole Button theme removes that stray white highlight. The
         title text is set on the TextBlock directly because the inner Button's own Foreground would otherwise
         win over inheritance. -->
    <Style Selector="dock|ToolPinItemControl /template/ TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource DockTabForegroundBrush}"/>
    </Style>
    <Style Selector="dock|ToolPinItemControl /template/ Button">
        <Setter Property="Theme" Value="{StaticResource PinTabButtonTheme}"/>
    </Style>
    <Style Selector="dock|ToolPinItemControl:pointerover">
        <Setter Property="Background" Value="{DynamicResource DockTabHoverBackgroundBrush}"/>
    </Style>
    <!-- Focused pinned tab → flat purple pill with on-primary text, matching dock|ToolTabStripItem:selected. -->
    <Style Selector="dock|ToolPinItemControl:focus-within">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentSolidBrush}"/>
    </Style>
    <Style Selector="dock|ToolPinItemControl:focus-within /template/ TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ThemeOnColorTextBrush}"/>
    </Style>

    <!-- Bool toggles render as a clay switch (see BoolPropertyView); give the track a touch more roundness. -->
    <Style Selector="ToggleSwitch">
        <Setter Property="MinWidth" Value="0"/>
    </Style>

    <!-- A clay-pressed vertical divider for the toolbar: a thin rounded groove (dark hairline + light
         lower-right highlight) so it reads as moulded into the surface rather than a flat line. -->
    <Style Selector="Border.claySeparator">
        <Setter Property="Width" Value="2"/>
        <Setter Property="Margin" Value="6,5"/>
        <Setter Property="CornerRadius" Value="1"/>
        <Setter Property="Background" Value="#26000000"/>
        <Setter Property="BoxShadow" Value="1 0 0 0 #40FFFFFF"/>
    </Style>

    <!-- Top-level toolbar menu separators get the same clay-groove look (a thin vertical pressed line),
         turning the gaps between File / Build / Debug / … into moulded dividers. Dropdown separators (inside
         a MenuItem) are NOT matched by the direct-child selector, so they keep their normal horizontal rule. -->
    <Style Selector="Border.Toolbar Menu > Separator">
        <Setter Property="Width" Value="1"/>
        <Setter Property="MinHeight" Value="18"/>
        <Setter Property="Margin" Value="4,4"/>
        <Setter Property="Background" Value="#26000000"/>
        <Setter Property="BorderBrush" Value="#40FFFFFF"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>
</Styles>
