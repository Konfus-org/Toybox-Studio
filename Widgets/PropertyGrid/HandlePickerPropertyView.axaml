<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.HandlePickerPropertyView"
             x:DataType="local:HandlePickerPropertyViewModel">
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <Border Background="{DynamicResource ThemeWellBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0.5" CornerRadius="2"
                MinHeight="22" Padding="7,0">
            <DockPanel>
                <!-- Picker: opens the asset chooser filtered to this handle's type. -->
                <Button DockPanel.Dock="Right" Command="{Binding PickCommand}" Padding="2" Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                        ToolTip.Tip="Pick from asset database">
                    <local:IconView Width="15" Height="15" IconName="Database"/>
                </Button>
                <!-- Current reference as a hyperlink; clicking reveals it in the catalog. -->
                <Button Command="{Binding OpenCommand}" IsEnabled="{Binding HasReference}"
                        HorizontalAlignment="Left" HorizontalContentAlignment="Left"
                        Padding="0" Background="Transparent" BorderThickness="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}" FontSize="12"
                               Foreground="{DynamicResource SystemAccentColor}" TextDecorations="Underline"/>
                </Button>
            </DockPanel>
        </Border>
    </local:PropertyRow>
</UserControl>
