<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Toybox.Studio.Widgets.Dialogs"
        xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
        x:Class="Toybox.Studio.Widgets.Dialogs.SaveChangesDialog"
        x:DataType="local:SaveChangesDialogViewModel"
        Icon="/Assets/Icons/Toybox.png"
        Width="460" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Title="{Binding Title}">

    <StackPanel Margin="18" Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="14">
            <pg:IconView IconName="CircleHelp" IconColor="BLUE"
                         Width="30" Height="30" VerticalAlignment="Top"/>
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                       VerticalAlignment="Center" MaxWidth="360"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="toy" Content="Cancel" MinWidth="80" IsCancel="True"
                    Command="{Binding CancelCommand}"/>
            <Button Classes="toy" Content="Don't Save" MinWidth="80"
                    Command="{Binding DiscardCommand}"/>
            <Button Classes="action" Content="Save" MinWidth="80" IsDefault="True"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
