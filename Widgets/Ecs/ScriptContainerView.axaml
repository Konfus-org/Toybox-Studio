<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ecs="using:Toybox.Studio.Widgets.Ecs"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.Ecs.ScriptContainerView"
             x:DataType="ecs:ScriptContainerViewModel">

    <UserControl.Styles>
        <!-- Each script binding reads like a component: same darkest header band, collapsible by its chevron.
             The enable checkbox sits to the right of the band, outside the collapse toggle. -->
        <Style Selector="Border.scriptBand">
            <Setter Property="Background" Value="{DynamicResource ThemeHeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
            <Setter Property="Padding" Value="2,6"/>
        </Style>
        <Style Selector="ToggleButton.scriptHeaderToggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ToggleButton.scriptHeaderToggle /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.scriptHeaderToggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ThemeBandBrush}"/>
        </Style>
        <Style Selector="ToggleButton.scriptHeaderToggle Path.scriptChevron">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        </Style>
        <Style Selector="ToggleButton.scriptHeaderToggle:checked Path.scriptChevron">
            <Setter Property="RenderTransform">
                <RotateTransform Angle="90"/>
            </Setter>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Bindings}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ecs:ScriptBindingViewModel">
                    <!-- Card is hidden under search only when neither the script title nor any override matches. -->
                    <StackPanel>
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static pg:AnyTrueConverter.Instance}">
                                <Binding Path="TitleMatchesFilter"/>
                                <Binding Path="#OverrideGrid.HasVisibleItems"/>
                            </MultiBinding>
                        </StackPanel.IsVisible>

                        <Border Classes="scriptBand">
                            <DockPanel>
                                <!-- Enable toggle, outside the collapse button so clicking it never collapses. -->
                                <CheckBox DockPanel.Dock="Right" Margin="6,0,8,0" VerticalAlignment="Center"
                                          IsChecked="{Binding Enabled}"
                                          ToolTip.Tip="Run this script"/>
                                <ToggleButton x:Name="ScriptToggle" Classes="scriptHeaderToggle" IsChecked="True">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="15" Margin="2,0,0,0"
                                                VerticalAlignment="Center">
                                            <Path Classes="scriptChevron" Width="8" Height="8" Stretch="Uniform"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Fill="{DynamicResource ThemeTextBrush}" Data="M 0,0 L 4,4 L 0,8 Z"/>
                                        </Border>
                                        <pg:IconView DockPanel.Dock="Left" Width="15" Height="15" Margin="6,0,6,0"
                                                     VerticalAlignment="Center"
                                                     IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
                                        <TextBlock Text="{Binding Title}" FontWeight="Medium"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </ToggleButton>
                            </DockPanel>
                        </Border>

                        <StackPanel IsVisible="{Binding #ScriptToggle.IsChecked}">
                            <pg:PropertyGridView x:Name="OverrideGrid" Items="{Binding Overrides}"
                                                 Filter="{Binding Filter}"/>
                            <!-- A binding with no overrides still shows its header; this fills the empty body. -->
                            <TextBlock Text="No overrides." Margin="12,6" FontSize="11" Opacity="0.5"
                                       IsVisible="{Binding !HasOverrides}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
