<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.EntityInspector"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:ghost="using:Toybox.Studio.Widgets.Ghost"
             x:Class="Toybox.Studio.Widgets.EntityInspector.EntityInspectorView"
             x:DataType="local:EntityInspectorViewModel">

    <DockPanel Margin="4">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6" Orientation="Horizontal" Spacing="8"
                    IsVisible="{Binding HasSelection}">
            <TextBlock Text="{Binding Entity.Name, FallbackValue=''}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Subtitle}" Opacity="0.6" VerticalAlignment="Center"/>
        </StackPanel>

        <Panel>
            <ghost:GhostView Message="No entity selected." IsVisible="{Binding !HasSelection}"/>

            <ScrollViewer IsVisible="{Binding HasSelection}">
                <ItemsControl ItemsSource="{Binding Components}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:ComponentGroupViewModel">
                            <Expander Header="{Binding Name}" IsExpanded="True" Margin="0,0,0,8" Padding="8,4"
                                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <pg:PropertyGridView Items="{Binding Properties}"/>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</UserControl>
