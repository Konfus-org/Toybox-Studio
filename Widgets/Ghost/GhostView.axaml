<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.Ghost"
             x:Class="Toybox.Studio.Widgets.Ghost.GhostView"
             x:Name="Root">
    <!-- Reusable empty/loading state: a ghost, a message below, and the same message as a tooltip.
         Fills whatever hosts it and centres its content. -->
    <Panel ToolTip.Tip="{Binding #Root.Message}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
            <TextBlock Text="👻" FontSize="56" Opacity="0.35" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding #Root.Message}" Opacity="0.5" HorizontalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
        </StackPanel>
    </Panel>
</UserControl>
