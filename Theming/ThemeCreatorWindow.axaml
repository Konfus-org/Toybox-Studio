<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="using:Toybox.Studio.Shell"
        xmlns:colors="using:Toybox.Studio.Widgets.Colors"
        x:Class="Toybox.Studio.Shell.ThemeCreatorWindow"
        x:DataType="shell:ThemeCreatorViewModel"
        Width="420" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Theme Creator">

    <ScrollViewer MaxHeight="640" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="10">
            <TextBlock Text="Create a new theme" FontWeight="SemiBold" FontSize="16"/>
            <TextBlock Text="Built-in themes can't be edited. This saves a new theme and applies it."
                       Opacity="0.6" TextWrapping="Wrap"/>

            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" Margin="0,6,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2" Text="{Binding Name}" PlaceholderText="My Theme"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Variant" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,2" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding Variants}" SelectedItem="{Binding SelectedVariant}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Corner radius" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="0,2" Minimum="0" Maximum="24"
                               Increment="1" FormatString="0.#" Value="{Binding CornerRadius}"/>
            </Grid>

            <TextBlock Text="Typography" FontWeight="SemiBold" Margin="0,6,0,0"/>
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Font" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2" Text="{Binding FontFamily}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Font size" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,2" Minimum="8" Maximum="32"
                               Increment="0.5" FormatString="0.#" Value="{Binding FontSize}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Monospace" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2" Text="{Binding MonospaceFamily}"/>
            </Grid>

            <TextBlock Text="Palette" FontWeight="SemiBold" Margin="0,6,0,0"/>
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Primary" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="0" Grid.Column="1" Margin="0,2" Color="{Binding Primary}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Secondary" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="1" Grid.Column="1" Margin="0,2" Color="{Binding Secondary}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tertiary" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="2" Grid.Column="1" Margin="0,2" Color="{Binding Tertiary}"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Error" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="3" Grid.Column="1" Margin="0,2" Color="{Binding Error}"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Warning" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="4" Grid.Column="1" Margin="0,2" Color="{Binding Warning}"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Info" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="5" Grid.Column="1" Margin="0,2" Color="{Binding Info}"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Success" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="6" Grid.Column="1" Margin="0,2" Color="{Binding Success}"/>
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Background" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="7" Grid.Column="1" Margin="0,2" Color="{Binding Background}"/>
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Surface" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="8" Grid.Column="1" Margin="0,2" Color="{Binding Surface}"/>
                <TextBlock Grid.Row="9" Grid.Column="0" Text="Text" VerticalAlignment="Center"/>
                <colors:ColorPickerField Grid.Row="9" Grid.Column="1" Margin="0,2" Color="{Binding Text}"/>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ThemeErrorBrush}"
                       TextWrapping="Wrap" IsVisible="{Binding HasError}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,6,0,0">
                <Button Content="Cancel" MinWidth="80" Command="{Binding CancelCommand}"/>
                <Button Content="Create" MinWidth="80" Command="{Binding CreateCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
