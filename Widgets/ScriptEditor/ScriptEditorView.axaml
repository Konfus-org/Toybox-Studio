<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:se="using:Toybox.Studio.Widgets.ScriptEditor"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.ScriptEditor.ScriptEditorView"
             x:DataType="se:ScriptEditorViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource ThemeBackgroundBrush}">

        <!-- Tab strip (one tab per open document) with the hot-reload bolt pinned at the far right. -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeHeaderBrush}" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                IsVisible="{Binding HasTabs}">
            <DockPanel>
                <ToggleButton DockPanel.Dock="Right" Margin="4,0,6,0" Padding="6,2"
                              Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                              IsChecked="{Binding HotReload.Enabled, Mode=TwoWay}"
                              ToolTip.Tip="Hot reload scripts on save">
                    <pg:IconView Width="15" Height="15" IconName="Zap"
                                 Foreground="{DynamicResource ThemeWarningBrush}"/>
                </ToggleButton>
                <ListBox ItemsSource="{Binding Tabs}"
                         SelectedItem="{Binding ActiveTab, Mode=TwoWay}"
                         Background="Transparent" Padding="0" BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="se:ScriptTabViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource ThemeTextBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="●" Foreground="{DynamicResource ThemeWarningBrush}"
                                           FontSize="{DynamicResource ThemeFontSizeSmall}" VerticalAlignment="Center"
                                           IsVisible="{Binding IsDirty}"/>
                                <Button Command="{Binding CloseCommand}"
                                        Content="✕" FontSize="{DynamicResource ThemeFontSizeSmall}" Padding="4,0"
                                        MinWidth="0" MinHeight="0"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource ThemeMutedTextBrush}"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Editor surface plus its empty/error overlays. The WebView is a native overlay (it always paints
             on top), so it's hidden when no document is open — otherwise its blank "untitled" buffer would
             cover the ghost. -->
        <Panel Grid.Row="1">
            <se:MonacoEditorControl Session="{Binding Session}" IsVisible="{Binding HasTabs}"/>

            <StackPanel IsVisible="{Binding ShowEmptyState}" Spacing="18"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- ASCII ghost for the empty editor. Monospace + tight line height + left-aligned within a
                     centred block so the art keeps its shape. -->
                <TextBlock Text="{Binding EmptyGhost}"
                           FontFamily="{DynamicResource ThemeMonoFontFamily}" FontSize="10" LineHeight="11"
                           Foreground="{DynamicResource ThemeMutedTextBrush}" Opacity="0.6"
                           HorizontalAlignment="Center" TextAlignment="Left"/>
                <TextBlock Foreground="{DynamicResource ThemeMutedTextBrush}" HorizontalAlignment="Center"
                           TextAlignment="Center" MaxWidth="320"
                           Text="No script open.&#x0a;Open an entity's Script tab and click Pop out to edit it here."/>
            </StackPanel>

            <TextBlock IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" Foreground="{DynamicResource ThemeErrorBrush}" MaxWidth="360"
                       Text="{Binding ErrorMessage}"/>
        </Panel>

        <!-- Status bar: compile state (placeholder until Phase 4), cursor position, language. -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeAccentSolidBrush}" Padding="10,3">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource ThemeOnColorTextBrush}"
                           Text="{Binding LanguageStatus}"/>
                <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource ThemeOnColorTextBrush}"
                           Text="UTF-8" Margin="14,0,0,0"/>
                <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource ThemeOnColorTextBrush}"
                           Text="{Binding CursorText}"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
