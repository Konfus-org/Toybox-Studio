<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:colors="using:Toybox.Studio.Widgets.Colors"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.ColorPropertyView"
             x:DataType="local:ColorPropertyViewModel">
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <Panel>
            <!-- Editable: the picker writes each channel back through the view-model on change. -->
            <colors:ColorPickerField Color="{Binding Color, Mode=TwoWay}"
                                     HorizontalAlignment="Left"
                                     IsVisible="{Binding !IsReadOnly}"/>
            <!-- Read-only: a static swatch + hex readout. -->
            <Border Background="{DynamicResource ThemeWellBrush}"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0.5" CornerRadius="2"
                    Height="20" Padding="6,0" HorizontalAlignment="Left"
                    IsVisible="{Binding IsReadOnly}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Border Width="12" Height="12" CornerRadius="2" Background="{Binding Swatch}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"/>
                    <TextBlock Text="{Binding Hex}" VerticalAlignment="Center" FontSize="12"
                               FontFamily="{DynamicResource ThemeMonoFontFamily}"/>
                </StackPanel>
            </Border>
        </Panel>
    </local:PropertyRow>
</UserControl>
