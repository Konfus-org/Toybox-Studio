<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.ThemePickerPropertyView"
             x:DataType="local:ThemePickerPropertyViewModel">
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <ComboBox Classes="field" IsEnabled="{Binding !IsReadOnly}"
                  ItemsSource="{Binding Choices}" SelectedItem="{Binding Value}"/>
    </local:PropertyRow>
</UserControl>
