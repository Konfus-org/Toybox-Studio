<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Toybox.Studio.Widgets.Dialogs"
        xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
        x:Class="Toybox.Studio.Widgets.Dialogs.MessageDialog"
        x:DataType="local:MessageDialogViewModel"
        Icon="/Assets/Icons/Toybox.png"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Title="{Binding Title}">

    <StackPanel Margin="18" Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="14">
            <pg:IconView IconName="{Binding IconName}" IconColor="{Binding IconColor}"
                         Width="30" Height="30" VerticalAlignment="Top"/>
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                       VerticalAlignment="Center" MaxWidth="340"/>
        </StackPanel>
        <Button Classes="action" Content="{Binding OkText}" HorizontalAlignment="Right"
                MinWidth="80" IsDefault="True" Command="{Binding OkCommand}"/>
    </StackPanel>
</Window>
