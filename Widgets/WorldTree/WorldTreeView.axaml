<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:Toybox.Studio.Services"
             xmlns:local="using:Toybox.Studio.Widgets.WorldTree"
             xmlns:ghost="using:Toybox.Studio.Widgets.Ghost"
             x:Class="Toybox.Studio.Widgets.WorldTree.WorldTreeView"
             x:DataType="local:WorldTreeViewModel">

    <DockPanel Margin="4">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <Button DockPanel.Dock="Right" Classes="Basic"
                    ToolTip.Tip="Refresh" Command="{Binding RefreshCommand}">
                <PathIcon Data="{StaticResource RefreshIconGeometry}" Width="13" Height="13"/>
            </Button>
            <TextBlock Text="{Binding Summary}" Opacity="0.6" VerticalAlignment="Center"/>
        </DockPanel>

        <Panel>
            <TreeView ItemsSource="{Binding RootNodes}"
                      SelectedItem="{Binding SelectedNode}"
                      SelectionMode="Single"
                      IsVisible="{Binding HasScene}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="services:WorldNode">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <ghost:GhostView Message="No scene loaded." IsVisible="{Binding !HasScene}"/>
        </Panel>
    </DockPanel>
</UserControl>
