<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.ObjectPropertyView"
             x:DataType="local:ObjectPropertyViewModel">
    <!-- A nested struct renders as its own header row (type icon + name) followed by its child rows,
         which carry Depth + 1 so they indent and shade one level deeper. Always expanded. -->
    <StackPanel>
        <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                           Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}"
                           IsParent="True" IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                           IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
        <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpanded}"/>
    </StackPanel>
</UserControl>
