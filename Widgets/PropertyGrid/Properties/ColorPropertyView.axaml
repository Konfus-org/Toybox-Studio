<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:colors="using:Toybox.Studio.Widgets.Colors"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.ColorPropertyView"
             x:DataType="local:ColorPropertyViewModel">
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <Panel>
            <!-- Editable: our shared colour editor (solid-only), writing each channel back on change. The
                 outer Border keeps the colour view-model in scope so !IsReadOnly resolves; the editor itself
                 rebinds its DataContext to the solid-only ColorGradientViewModel. -->
            <Border HorizontalAlignment="Left" IsVisible="{Binding !IsReadOnly}">
                <colors:ColorGradientView DataContext="{Binding Editor}"/>
            </Border>
            <!-- Read-only: a static swatch + hex readout. -->
            <Border Background="{DynamicResource ThemeWellBrush}"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    Height="20" Padding="6,0" HorizontalAlignment="Left"
                    IsVisible="{Binding IsReadOnly}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <!-- The 12px chip keeps a small fixed rounding: the full theme radius would round it to a
                         circle. -->
                    <Border Width="12" Height="12" CornerRadius="3" Background="{Binding Swatch}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"/>
                    <TextBlock Text="{Binding Hex}" VerticalAlignment="Center"
                               FontSize="{DynamicResource ThemeFontSizeSmall}"
                               FontFamily="{DynamicResource ThemeMonoFontFamily}"/>
                </StackPanel>
            </Border>
        </Panel>
    </local:PropertyRow>
</UserControl>
