<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ecs="using:Toybox.Studio.Widgets.Ecs"
             xmlns:ghost="using:Toybox.Studio.Widgets.Ghost"
             x:Class="Toybox.Studio.Widgets.WorldTree.WorldTreeView"
             x:DataType="ecs:WorldViewModel">

    <DockPanel Margin="4">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <Button DockPanel.Dock="Right" Classes="Basic"
                    ToolTip.Tip="Refresh" Command="{Binding RefreshCommand}">
                <PathIcon Data="{StaticResource RefreshIconGeometry}" Width="13" Height="13"/>
            </Button>
            <TextBlock Text="{Binding Summary}" Opacity="0.6" VerticalAlignment="Center"/>
        </DockPanel>

        <Panel>
            <TreeView ItemsSource="{Binding RootEntities}"
                      SelectedItem="{Binding SelectedEntity}"
                      SelectionMode="Single"
                      IsVisible="{Binding HasWorld}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="ecs:EntityViewModel">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <ghost:GhostView Message="No world loaded." IsVisible="{Binding !HasWorld}"/>
        </Panel>
    </DockPanel>
</UserControl>
