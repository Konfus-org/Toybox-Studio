<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ecs="using:Toybox.Studio.Widgets.Ecs"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.Ecs.ScriptContainerView"
             x:DataType="ecs:ScriptContainerViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Bindings}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ecs:ScriptBindingViewModel">
                    <!-- Card is hidden under search only when neither the script title nor any override matches. -->
                    <StackPanel>
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static pg:AnyTrueConverter.Instance}">
                                <Binding Path="TitleMatchesFilter"/>
                                <Binding Path="#OverrideGrid.HasVisibleItems"/>
                            </MultiBinding>
                        </StackPanel.IsVisible>

                        <!-- A script binding is a section just like a component: the shared sectionHeader band
                             with the chevron pinned right and the whole band collapsing on click. The enable
                             checkbox sits to the right (before the chevron); as an interactive child it
                             swallows its own click, so ticking it never collapses the section. -->
                        <ToggleButton x:Name="ScriptToggle" Classes="sectionHeader" IsChecked="True">
                            <DockPanel>
                                <Path DockPanel.Dock="Right" Classes="sectionChevron" Width="8" Height="8"
                                      Stretch="Uniform" Margin="8,0,2,0" VerticalAlignment="Center"
                                      Fill="{DynamicResource ThemeAccentSolidBrush}" Data="M 0,0 L 4,4 L 0,8 Z"/>
                                <CheckBox DockPanel.Dock="Right" Margin="6,0,4,0" VerticalAlignment="Center"
                                          IsChecked="{Binding Enabled}"
                                          ToolTip.Tip="Run this script"/>
                                <pg:IconView DockPanel.Dock="Left" Width="15" Height="15" Margin="2,0,6,0"
                                             VerticalAlignment="Center"
                                             IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
                                <TextBlock Text="{Binding Title}" FontWeight="Medium"
                                           Foreground="{DynamicResource ThemeAccentSolidBrush}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </ToggleButton>

                        <StackPanel IsVisible="{Binding #ScriptToggle.IsChecked}">
                            <pg:PropertyGridView x:Name="OverrideGrid" Embedded="True"
                                                 Items="{Binding Overrides}"
                                                 Filter="{Binding Filter}"/>
                            <!-- A binding with no overrides still shows its header; this fills the empty body. -->
                            <TextBlock Text="No overrides." Margin="12,6" FontSize="11" Opacity="0.5"
                                       IsVisible="{Binding !HasOverrides}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
