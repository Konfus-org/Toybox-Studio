<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.ScriptLinkPropertyView"
             x:DataType="local:ScriptLinkPropertyViewModel">
    <UserControl.Styles>
        <!-- An unobtrusive link button: no fill, no border, no presenter band in any state — just the
             underlined accent text, dimming slightly on hover so it reads as interactive. -->
        <Style Selector="Button.scriptLink">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.scriptLink /template/ ContentPresenter#PART_ContentPresenter,
                         Button.scriptLink:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                         Button.scriptLink:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.scriptLink:pointerover">
            <Setter Property="Opacity" Value="0.75"/>
        </Style>
    </UserControl.Styles>
    <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                       Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}">
        <!-- Boxed like the other field editors for consistency; read-only reference that opens on click. -->
        <Border Classes="fieldHost">
            <DockPanel>
                <local:IconView DockPanel.Dock="Left" Width="14" Height="14" Margin="7,0,0,0" IconName="Code"
                                VerticalAlignment="Center" Foreground="{DynamicResource ThemeMutedTextBrush}"/>
                <Button Classes="scriptLink" HorizontalAlignment="Left" Margin="7,0,0,0"
                        VerticalAlignment="Center"
                        Command="{Binding OpenCommand}" IsEnabled="{Binding HasReference}">
                    <TextBlock Text="{Binding DisplayName}" FontSize="{DynamicResource ThemeFontSizeSmall}"
                               Foreground="{DynamicResource ThemeAccentSolidBrush}" TextDecorations="Underline"/>
                </Button>
            </DockPanel>
        </Border>
    </local:PropertyRow>
</UserControl>
