<Window xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:shell="using:Toybox.Studio.Shell"
                 xmlns:status="using:Toybox.Studio.Widgets.Status"
                 xmlns:searching="using:Toybox.Studio.Widgets.Searching"
                 xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
                 xmlns:workspace="using:Toybox.Studio.Shell.Workspace"
                 xmlns:dock="using:Dock.Avalonia.Controls"
                 xmlns:dockModel="using:Dock.Model.Avalonia.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="850"
                 x:Class="Toybox.Studio.Shell.MainWindow"
                 x:Name="RootWindow"
                 x:DataType="shell:ShellViewModel"
                 Icon="/Assets/Icons/Toybox.png"
                 Title="{Binding Title}"
                 Width="1440" Height="850">

    <!-- The menu items' InputGesture only displays the shortcut; these bind the actual hotkeys. -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAllCommand}"/>
    </Window.KeyBindings>

    <Window.Resources>
        <!-- Shared header for a favoritable menu action: type icon, label, and a trailing star that toggles
             whether the action appears in the generated Favorites menu. Used by both the main menus and the
             Favorites menu (so a starred action can be un-starred from either). -->
        <DataTemplate x:Key="FavoritableMenuHeader" x:DataType="shell:MenuActionViewModel">
            <DockPanel MinWidth="170">
                <ToggleButton DockPanel.Dock="Right" Classes="menuStar"
                              IsChecked="{Binding IsFavorite, Mode=OneWay}"
                              Command="{Binding ToggleFavoriteCommand}"
                              ToolTip.Tip="Add to Favorites">
                    <pg:IconView IconName="Star" IconColor="{Binding StarColor}" Width="12" Height="12"/>
                </ToggleButton>
                <pg:IconView DockPanel.Dock="Left" Width="14" Height="14" Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <!-- The per-item star: faint at rest, fades up on hover, gold when starred. Handles its own click so
             toggling it doesn't invoke the menu item's command. -->
        <Style Selector="ToggleButton.menuStar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Margin" Value="16,0,0,0"/>
            <Setter Property="Opacity" Value="0.35"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ToggleButton.menuStar:pointerover, ToggleButton.menuStar:checked">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ToggleButton.menuStar /template/ ContentPresenter#PART_ContentPresenter,
                         ToggleButton.menuStar:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border Classes="Toolbar" DockPanel.Dock="Top" Padding="8,3">
          <!-- Menu on the left; the quick-search is centred in the middle of the window (overlaid in the same
               grid cell, so it centres on the window rather than the space left of/right of the menu). -->
          <Grid VerticalAlignment="Center">
            <!-- A toy-groove Separator sits between each top-level option (styled via "Border.Toolbar Menu
                 > Separator" in AppStyles). Separators inside the dropdowns are unaffected. -->
            <Menu HorizontalAlignment="Left" VerticalAlignment="Center">
                <MenuItem Header="File">
                    <MenuItem Header="Open">
                        <MenuItem Header="{Binding OpenProjectAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                                  Command="{Binding OpenProjectAction.Command}"/>
                        <MenuItem Header="{Binding OpenAssetAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                                  Command="{Binding OpenAssetAction.Command}"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="{Binding SaveAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              InputGesture="Ctrl+S" Command="{Binding SaveAction.Command}"/>
                    <MenuItem Header="{Binding SaveAllAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              InputGesture="Ctrl+Shift+S" Command="{Binding SaveAllAction.Command}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Build">
                    <MenuItem Header="{Binding CompileAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              Command="{Binding CompileAction.Command}"/>
                    <Separator/>
                    <MenuItem Header="Ship">
                        <MenuItem Header="{Binding ShipDebugAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                                  Command="{Binding ShipDebugAction.Command}" CommandParameter="{Binding ShipDebugAction.Parameter}"/>
                        <MenuItem Header="{Binding ShipReleaseAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                                  Command="{Binding ShipReleaseAction.Command}" CommandParameter="{Binding ShipReleaseAction.Parameter}"/>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Debug">
                    <MenuItem Header="{Binding DebugEditorAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              Command="{Binding DebugEditorAction.Command}"/>
                    <MenuItem Header="{Binding AttachAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              Command="{Binding AttachAction.Command}"/>
                </MenuItem>
                <Separator/>
                <!-- Data-driven: one item per registered [Dockable], opened (or focused) by Id. -->
                <MenuItem Header="Windows" ItemsSource="{Binding Workspace.All}">
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem" x:DataType="workspace:DockableDescriptor"
                                      BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding Title}"/>
                            <Setter Property="Command"
                                    Value="{Binding #RootWindow.((shell:ShellViewModel)DataContext).Workspace.OpenDockableCommand}"/>
                            <Setter Property="CommandParameter" Value="{Binding Id}"/>
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Layout">
                    <MenuItem Header="{Binding SaveLayoutAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              Command="{Binding SaveLayoutAction.Command}"/>
                    <MenuItem Header="{Binding LoadLayoutAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              Command="{Binding LoadLayoutAction.Command}"/>
                    <MenuItem Header="{Binding ResetLayoutAction}" HeaderTemplate="{StaticResource FavoritableMenuHeader}"
                              Command="{Binding ResetLayoutAction.Command}"/>
                </MenuItem>
                <Separator/>
                <!-- Generated from the stars above: the starred actions, runnable straight from here. Hidden
                     until something is favorited. -->
                <MenuItem Header="Favorites" IsVisible="{Binding HasFavorites}"
                          ItemsSource="{Binding Favorites}">
                    <MenuItem.Icon>
                        <pg:IconView IconName="Star" IconColor="YELLOW" Width="14" Height="14"/>
                    </MenuItem.Icon>
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem" x:DataType="shell:MenuActionViewModel"
                                      BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding}"/>
                            <Setter Property="HeaderTemplate" Value="{StaticResource FavoritableMenuHeader}"/>
                            <Setter Property="Command" Value="{Binding Command}"/>
                            <Setter Property="CommandParameter" Value="{Binding Parameter}"/>
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
            </Menu>

            <!-- Centred quick-search. (The Play/Stop/Pause transport lives on the Game view, not here.) -->
            <searching:SearchBox HorizontalAlignment="Center" Width="300" VerticalAlignment="Center"
                                 Watermark="Search…" Text="{Binding ToolbarSearch}"/>
          </Grid>
        </Border>

        <Border Classes="StatusBar" DockPanel.Dock="Bottom">
            <status:StatusView DataContext="{Binding Status}"/>
        </Border>

        <!-- Factory + the real (saved or default) layout are assigned in code from Workspace; the layout is
             data-driven, saved on exit. The inline empty RootDock is just a placeholder so the dock chrome
             has a non-null Layout to bind against during construction (otherwise Layout.* binds log errors
             before Workspace.Bind runs); it's replaced the moment the shell DataContext arrives. -->
        <dock:DockControl x:Name="DockHost" Margin="6">
            <dock:DockControl.Layout>
                <dockModel:RootDock/>
            </dock:DockControl.Layout>
        </dock:DockControl>
    </DockPanel>
</Window>
