<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.GameToolbar"
             x:Class="Toybox.Studio.Widgets.GameToolbar.GameToolbarView"
             x:DataType="local:GameToolbarViewModel">

    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
        <Button Classes="Basic" Width="36"
                AutomationProperties.Name="PlayStop"
                ToolTip.Tip="{Binding PlayOrStopTip}"
                Command="{Binding PlayOrStopCommand}">
            <Panel>
                <PathIcon Data="{StaticResource PlayIconGeometry}" Width="14" Height="14"
                          IsVisible="{Binding !IsPlaying}"/>
                <PathIcon Data="{StaticResource StopIconGeometry}" Width="14" Height="14"
                          IsVisible="{Binding IsPlaying}"/>
            </Panel>
        </Button>
        <ToggleButton Width="36"
                      AutomationProperties.Name="Pause"
                      ToolTip.Tip="Pause"
                      IsVisible="{Binding IsPlaying}"
                      IsChecked="{Binding IsPaused, Mode=OneWay}"
                      Command="{Binding TogglePauseCommand}">
            <PathIcon Data="{StaticResource PauseIconGeometry}" Width="14" Height="14"/>
        </ToggleButton>
    </StackPanel>
</UserControl>
