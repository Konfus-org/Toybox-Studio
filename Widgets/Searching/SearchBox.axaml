<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:controls="using:Toybox.Studio.Widgets.Searching"
             xmlns:behaviors="using:Toybox.Studio.Widgets.Behaviors.Animations"
             x:Class="Toybox.Studio.Widgets.Searching.SearchBox">

    <UserControl.Styles>
        <!-- The inner TextBox is chrome-less: it must not draw its own border element or cast the global
             toy shadow (that's what made the search field look like it had a second, mismatched outline +
             shadow). The visible pill is the outer Border below. -->
        <Style Selector="TextBox.searchInner /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
        </Style>
        <!-- No shadow on the search field (shadows live on panels/bars/flyouts only); just light the ring on focus. -->
        <Style Selector="Border.searchPill:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
    </UserControl.Styles>

    <Border x:Name="Pill" Classes="searchPill"
            Background="{DynamicResource ThemeSurfaceBrush}"
            BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.5"
            CornerRadius="10" Padding="9,0" MinHeight="30">
        <DockPanel>
            <PathIcon DockPanel.Dock="Left"
                      Data="{StaticResource SearchIconGeometry}"
                      Width="13" Height="13" Opacity="0.5"
                      Margin="0,0,6,0" VerticalAlignment="Center"/>

            <Button DockPanel.Dock="Right" Classes="Basic"
                    Padding="2" Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Clear search"
                    Click="OnClearClicked"
                    IsVisible="{Binding Text, RelativeSource={RelativeSource AncestorType=controls:SearchBox}, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}">
                <PathIcon Data="{StaticResource CloseIconGeometry}" Width="10" Height="10" Opacity="0.6"/>
            </Button>

            <TextBox Name="PART_TextBox" Classes="searchInner"
                     behaviors:TextWiggle.Target="{Binding #Pill}"
                     Background="Transparent" BorderThickness="0"
                     Padding="0" MinHeight="0" VerticalContentAlignment="Center"
                     PlaceholderText="{Binding Watermark, RelativeSource={RelativeSource AncestorType=controls:SearchBox}}"
                     Text="{Binding Text, RelativeSource={RelativeSource AncestorType=controls:SearchBox}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DockPanel>
    </Border>
</UserControl>
