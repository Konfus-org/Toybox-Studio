        <!-- Theme token defaults. ThemeManager overwrites these from the active Theme.json at
             startup; they exist so DynamicResource lookups resolve at design time and on first
             frame. -->
        <SolidColorBrush x:Key="ThemePrimaryBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="ThemeSecondaryBrush" Color="#6E7B8B"/>
        <SolidColorBrush x:Key="ThemeTertiaryBrush" Color="#8A63D2"/>
        <SolidColorBrush x:Key="ThemeErrorBrush" Color="#E74C3C"/>
        <SolidColorBrush x:Key="ThemeWarningBrush" Color="#F1C40F"/>
        <SolidColorBrush x:Key="ThemeInfoBrush" Color="#3498DB"/>
        <SolidColorBrush x:Key="ThemeSuccessBrush" Color="#2ECC71"/>
        <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#0E1525"/>
        <SolidColorBrush x:Key="ThemeSurfaceBrush" Color="#16203A"/>
        <SolidColorBrush x:Key="ThemeTextBrush" Color="#E8ECF4"/>
        <FontFamily x:Key="ThemeFontFamily">Inter</FontFamily>
        <FontFamily x:Key="ThemeMonoFontFamily">Cascadia Mono, Consolas, monospace</FontFamily>
        <x:Double x:Key="ThemeFontSize">13</x:Double>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml"/>
        <StyleInclude Source="/Shell/ShellStyles.axaml"/>
    </Application.Styles>
</Application>
