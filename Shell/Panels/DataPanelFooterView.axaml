<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:panels="using:Toybox.Studio.Shell.Panels"
             x:Class="Toybox.Studio.Shell.Panels.DataPanelFooterView"
             x:DataType="panels:DataPanel">

    <!-- Docked at the bottom of a buffered data panel: explicit Save/Cancel for the working copy. Both stay
         disabled while clean (nothing to commit or discard). -->
    <Border Background="{DynamicResource ThemeHeaderBrush}"
            BorderBrush="{DynamicResource ThemeBorderBrush}"
            BorderThickness="0,0.5,0,0" Padding="10,7">
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Cancel" MinWidth="80"
                    Command="{Binding CancelCommand}" IsEnabled="{Binding IsDirty}"/>
            <Button Content="Save" Classes="action" MinWidth="80"
                    Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}"/>
        </StackPanel>
    </Border>
</UserControl>
