<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:util="using:Toybox.Studio.Widgets.Behaviors" xmlns:anim="using:Toybox.Studio.Widgets.Behaviors.Animations"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.ObjectPropertyView"
             x:DataType="local:ObjectPropertyViewModel">
    <!-- A struct followed by its child rows (Depth + 1, so they shade and indent one level deeper). A
         ROOT-level struct renders as the accent section band (like a category/component). A NESTED struct
         renders as an ordinary property row — identical gutter, depth tint and alignment to its sibling rows —
         that toggles on a tap anywhere, with a right-hand chevron showing the open state. -->
    <StackPanel IsVisible="{Binding Visible}">
        <ToggleButton Classes="sectionHeader" IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                      IsVisible="{Binding !IsNested}"
                      Background="{Binding Depth, Converter={x:Static local:DepthToBrushConverter.Instance}}">
            <DockPanel Margin="{Binding Depth, Converter={x:Static local:DepthToIndentConverter.Instance}}">
                <!-- A root struct shows its default-state indicator (and reset) just like a row; the button
                     swallows its own click so resetting never toggles the band. It's pinned to the far-right
                     edge (after the chevron) to match the leaf-row and list-header part order. A ContentControl
                     (not a bare ContentPresenter) so the StateIndicatorPart's implicit DataTemplate resolves:
                     a bare presenter outside a control template has no TemplatedParent and renders nothing. -->
                <ContentControl DockPanel.Dock="Right" Content="{Binding StateIndicator}"
                                VerticalAlignment="Center"/>
                <!-- Disclosure chevron on the LEFT, before the icon/label, like a tree node. -->
                <Path DockPanel.Dock="Left" Classes="sectionChevron" Width="8" Height="8" Stretch="Uniform"
                      Margin="2,0,8,0" VerticalAlignment="Center" Data="M 0,0 L 8,4 L 0,8 Z"/>
                <local:IconView DockPanel.Dock="Left" Width="15" Height="15" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
                <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"
                           ToolTip.Tip="{Binding Description}"/>
            </DockPanel>
        </ToggleButton>

        <!-- Nested struct: an ordinary property row that toggles on tap; the disclosure chevron and the state
             indicator render in the row's own Dropdown / State slots (from the composite's parts). -->
        <local:PropertyRow HeaderText="{Binding Name}" Description="{Binding Description}"
                           Depth="{Binding Depth}" IsReadOnly="{Binding IsReadOnly}"
                           IconName="{Binding Icon}" IconColor="{Binding IconColor}"
                           IsVisible="{Binding IsNested}"
                           anim:ExpandNod.State="{Binding IsExpanded}"
                           util:ToggleOnTap.Enabled="True"
                           util:ToggleOnTap.State="{Binding IsExpanded, Mode=TwoWay}"/>

        <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpanded}"/>
    </StackPanel>
</UserControl>
