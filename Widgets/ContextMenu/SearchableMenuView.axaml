<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cm="using:Toybox.Studio.Widgets.ContextMenu"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:search="using:Toybox.Studio.Widgets.Searching"
             x:Class="Toybox.Studio.Widgets.ContextMenu.SearchableMenuView"
             x:DataType="cm:SearchableMenuViewModel"
             MinWidth="220" MaxWidth="320" MaxHeight="460">

    <UserControl.Styles>
        <!-- One menu row: chrome-less button that fills the row and highlights on hover, like a MenuItem. -->
        <Style Selector="Button.menuRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
        </Style>
        <Style Selector="Button.menuRow:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}"/>
        </Style>

        <!-- The per-row star: invisible at rest, fades up on hover, gold when starred. -->
        <Style Selector="ToggleButton.star">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Opacity" Value="0.3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip.Tip" Value="Add to Favorites"/>
        </Style>
        <Style Selector="ToggleButton.star:pointerover, ToggleButton.star:checked">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ToggleButton.star /template/ ContentPresenter#PART_ContentPresenter,
                         ToggleButton.star:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Border.menuSeparator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="6,4"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBorderBrush}"/>
        </Style>

        <Style Selector="TextBlock.menuGroupHeader">
            <Setter Property="FontSize" Value="{DynamicResource ThemeFontSizeSmall}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeMutedTextBrush}"/>
            <Setter Property="Margin" Value="8,4,8,2"/>
        </Style>

        <!-- The "Favorites" submenu header: a menu row that expands/collapses the starred items beneath it. -->
        <Style Selector="ToggleButton.favoritesHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
        </Style>
        <Style Selector="ToggleButton.favoritesHeader:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                         ToggleButton.favoritesHeader:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}"/>
        </Style>
        <!-- Disclosure chevron: points right when collapsed, rotates down when expanded. -->
        <Style Selector="ToggleButton.favoritesHeader Path.favChevron">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="ToggleButton.favoritesHeader:checked Path.favChevron">
            <Setter Property="RenderTransform">
                <RotateTransform Angle="90"/>
            </Setter>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!-- Shared row template for both the Favorites group and the full list. -->
        <DataTemplate x:Key="MenuRow" x:DataType="cm:MenuEntryViewModel">
            <Panel>
                <Border Classes="menuSeparator" IsVisible="{Binding IsSeparator}"/>
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsSeparator}">
                    <Button Grid.Column="0" Classes="menuRow" Command="{Binding RunCommand}">
                        <DockPanel>
                            <pg:IconView DockPanel.Dock="Left" Width="14" Height="14" Margin="0,0,8,0"
                                         VerticalAlignment="Center"
                                         IconName="{Binding IconName}" IconColor="{Binding IconColor}"/>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding Gesture}"
                                       IsVisible="{Binding HasGesture}" Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource ThemeFontSizeSmall}"
                                       Foreground="{DynamicResource ThemeMutedTextBrush}"/>
                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Button>
                    <ToggleButton Grid.Column="1" Classes="star"
                                  IsVisible="{Binding IsFavoritable}"
                                  IsChecked="{Binding IsFavorite, Mode=OneWay}"
                                  Command="{Binding ToggleFavoriteCommand}">
                        <pg:IconView Width="13" Height="13" IconName="Star"
                                     IconColor="{Binding StarColor}"/>
                    </ToggleButton>
                </Grid>
            </Panel>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource ThemeSurfaceBrush}"
            BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
            CornerRadius="{DynamicResource ControlCornerRadius}" Padding="4">
        <DockPanel>
            <search:SearchBox x:Name="SearchBox" DockPanel.Dock="Top" Margin="2,2,2,4"
                              Text="{Binding Filter, Mode=TwoWay}" Watermark="Search…"/>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Favorites submenu: a collapsible "Favorites" row that expands the starred items for this
                         menu beneath it (auto-expanded while searching). -->
                    <StackPanel IsVisible="{Binding HasFavorites}">
                        <ToggleButton Classes="favoritesHeader" IsChecked="{Binding IsFavoritesExpanded}">
                            <DockPanel>
                                <pg:IconView DockPanel.Dock="Left" Width="14" Height="14" Margin="0,0,8,0"
                                             VerticalAlignment="Center" IconName="Star" IconColor="YELLOW"/>
                                <Path DockPanel.Dock="Right" Classes="favChevron" Width="8" Height="8"
                                      Stretch="Uniform" VerticalAlignment="Center" Margin="8,0,0,0"
                                      Fill="{DynamicResource ThemeTextBrush}" Data="M 0,0 L 8,4 L 0,8 Z"/>
                                <TextBlock Text="Favorites" VerticalAlignment="Center" FontWeight="Medium"/>
                            </DockPanel>
                        </ToggleButton>
                        <ItemsControl ItemsSource="{Binding Favorites}" ItemTemplate="{StaticResource MenuRow}"
                                      IsVisible="{Binding FavoritesShown}" Margin="14,0,0,0"/>
                        <Border Classes="menuSeparator"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource MenuRow}"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
