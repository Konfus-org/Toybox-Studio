<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ecs="using:Toybox.Studio.Widgets.Ecs"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:ghost="using:Toybox.Studio.Widgets.Ghost"
             xmlns:search="using:Toybox.Studio.Widgets.Searching"
             x:Class="Toybox.Studio.Widgets.EntityInspector.EntityInspectorView"
             x:DataType="ecs:WorldViewModel">

    <DockPanel>
        <!-- Entity header: name on the left, id pinned right. Scoped to SelectedEntity so its inner bindings
             resolve against a null context (not a null SelectedEntity.* path) when nothing is selected. -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ThemeHeaderBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="10,7" IsVisible="{Binding HasSelection}">
            <DockPanel DataContext="{Binding SelectedEntity}" x:DataType="ecs:EntityViewModel">
                <TextBlock DockPanel.Dock="Right" Text="{Binding Subtitle}" Opacity="0.55"
                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0"/>
                <!-- Wholesale enable toggle: a disabled entity is skipped by every runtime system but stays
                     selected and editable here. Same toy switch as the component/script headers. -->
                <ToggleSwitch DockPanel.Dock="Left" Margin="0,0,8,0" VerticalAlignment="Center"
                              IsChecked="{Binding IsEnabled}"
                              OnContent="" OffContent="" MinHeight="0" Padding="0"
                              ToolTip.Tip="Enable this entity"/>
                <TextBlock Text="{Binding Name, FallbackValue=''}" FontWeight="Medium"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Panel>
            <ghost:GhostView Message="No entity selected." IsVisible="{Binding !HasSelection}"/>

            <DockPanel IsVisible="{Binding HasSelection}">
                <!-- One inspector search, above the tabs: filters every property grid (Components and
                     Scripts) by header or value. A component whose grid has no matching rows hides itself. -->
                <search:SearchBox DockPanel.Dock="Top" Margin="4,6,4,0"
                                  Text="{Binding ComponentSearch, Mode=TwoWay}"
                                  Watermark="Search properties…"/>

                <TabControl Classes="inspectorTabs" Margin="4,10,4,4">
                <!-- Components: every non-script component, stacked under its own collapsible header. -->
                <TabItem Header="Components">
                    <!-- Scoped to SelectedEntity so the inner bindings are single-step (HasComponents/
                         Components) and resolve against a null context — not a null SelectedEntity.* path —
                         when nothing is selected. -->
                    <Panel DataContext="{Binding SelectedEntity}" x:DataType="ecs:EntityViewModel">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding HasComponents}">
                        <ItemsControl ItemsSource="{Binding Components}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="ecs:ComponentViewModel">
                                    <!-- Components are flat sections of one cohesive panel (no per-component
                                         card, no gradient): a flat header band, then the embedded grid's rows
                                         flow beneath on the same surface. -->
                                    <StackPanel IsVisible="{Binding #ComponentGrid.HasVisibleItems}">
                                        <ToggleButton x:Name="CompToggle" Classes="sectionHeader" IsChecked="True">
                                            <DockPanel>
                                                <!-- Disclosure chevron on the LEFT, before the icon/label. -->
                                                <Path DockPanel.Dock="Left" Classes="sectionChevron"
                                                      Width="8" Height="8" Stretch="Uniform" Margin="2,0,8,0"
                                                      VerticalAlignment="Center"
                                                      Fill="{DynamicResource ThemeAccentSolidBrush}"
                                                      Data="M 0,0 L 8,4 L 0,8 Z"/>
                                                <!-- Enable toggle (far right): a toy switch like every other
                                                     bool. As an interactive child it swallows its own click, so
                                                     flipping it never collapses the section. -->
                                                <ToggleSwitch DockPanel.Dock="Right" Margin="6,0,4,0"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding IsEnabled}"
                                                              IsVisible="{Binding HasEnableToggle}"
                                                              OnContent="" OffContent="" MinHeight="0" Padding="0"
                                                              ToolTip.Tip="Enable this component"/>
                                                <pg:IconView DockPanel.Dock="Left" Width="15" Height="15"
                                                             Margin="0,0,6,0" VerticalAlignment="Center"
                                                             IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"
                                                           Foreground="{DynamicResource ThemeAccentSolidBrush}"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </ToggleButton>
                                        <pg:PropertyGridView x:Name="ComponentGrid" Embedded="True"
                                                             Items="{Binding Properties}"
                                                             Filter="{Binding Filter}"
                                                             IsVisible="{Binding #CompToggle.IsChecked}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <ghost:GhostView Message="No components on this entity."
                                     IsVisible="{Binding !HasComponents}"/>
                    </Panel>
                </TabItem>

                <!-- Scripts: the script container, one card per bound script (its overrides as fields). -->
                <TabItem Header="Scripts">
                    <!-- Scoped to SelectedEntity so the inner bindings are single-step (HasScripts/Scripts)
                         and resolve against a null context when nothing is selected. -->
                    <Panel DataContext="{Binding SelectedEntity}" x:DataType="ecs:EntityViewModel">
                        <!-- Visibility lives on the wrapper so it resolves against the entity; the inner
                             view overrides its own DataContext to the script container. -->
                        <Panel IsVisible="{Binding HasScripts}">
                            <ecs:ScriptContainerView DataContext="{Binding Scripts}"/>
                        </Panel>
                        <ghost:GhostView Message="No scripts on this entity."
                                         IsVisible="{Binding !HasScripts}"/>
                    </Panel>
                </TabItem>

                <!-- Json (debug only): the raw component JSON, editable, applied per-component. -->
                <TabItem Header="Json" IsVisible="{x:Static ecs:EntityViewModel.IsDebug}">
                    <Grid RowDefinitions="*,Auto" Margin="6"
                          DataContext="{Binding SelectedEntity}" x:DataType="ecs:EntityViewModel">
                        <TextBox Grid.Row="0" Text="{Binding JsonDraft, Mode=TwoWay}"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                 FontFamily="{DynamicResource ThemeMonoFontFamily}"
                                 FontSize="{DynamicResource ThemeFontSizeSmall}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Apply" Classes="action" Command="{Binding ApplyJsonCommand}"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                </TabControl>
            </DockPanel>
        </Panel>
    </DockPanel>
</UserControl>
