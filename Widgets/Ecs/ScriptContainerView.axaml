<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ecs="using:Toybox.Studio.Widgets.Ecs"
             xmlns:pg="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:se="using:Toybox.Studio.Widgets.ScriptEditor"
             xmlns:sc="using:Toybox.Studio.Services.Scripting"
             x:Class="Toybox.Studio.Widgets.Ecs.ScriptContainerView"
             x:DataType="ecs:ScriptContainerViewModel">

    <UserControl.DataTemplates>
        <!-- The expanded script's inline source editor. Hosted per-card inside the scroll (below) at a fixed
             working height; Monaco scrolls its own content, so the whole card stack still scrolls as one. -->
        <DataTemplate x:DataType="se:InlineScriptEditorViewModel">
            <DockPanel>
                <!-- .h / .cpp toggle (only when the script has both). -->
                <ListBox DockPanel.Dock="Top" ItemsSource="{Binding Documents}"
                         SelectedItem="{Binding ActiveDocument, Mode=TwoWay}"
                         IsVisible="{Binding HasMultipleFiles}"
                         Background="{DynamicResource ThemeHeaderBrush}" Padding="0"
                         BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ThemeBorderBrush}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="sc:ScriptDocument">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="{Binding FileName}" FontSize="{DynamicResource ThemeFontSizeSmall}"
                                           Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="●" FontSize="{DynamicResource ThemeFontSizeSmall}"
                                           Foreground="{DynamicResource ThemeWarningBrush}"
                                           VerticalAlignment="Center" IsVisible="{Binding IsDirty}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Panel>
                    <Border CornerRadius="{DynamicResource ControlCornerRadius}" ClipToBounds="True"
                            BorderThickness="1" BorderBrush="{DynamicResource ThemeBorderBrush}">
                        <se:MonacoEditorControl Session="{Binding Session}" Offscreen="True"/>
                    </Border>
                    <!-- Spinner over the editor until the page has loaded; the WebView loads off the UI
                         thread, so this never blocks. -->
                    <Border IsVisible="{Binding !IsReady}" CornerRadius="{DynamicResource ControlCornerRadius}"
                            Background="{DynamicResource ThemeBackgroundBrush}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                            <ProgressBar IsIndeterminate="True" Width="140"/>
                            <TextBlock Text="Loading source…" FontSize="{DynamicResource ThemeFontSizeSmall}"
                                       Foreground="{DynamicResource ThemeMutedTextBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Panel>
            </DockPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <!-- Everything — every card's header, fields, Source band AND the expanded inline editor — lives in one
         ScrollViewer, so a tall stack of bound scripts (or an open source editor) always scrolls instead of
         being clipped. Only one Source section is open at a time (coordinated by the container). -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Bindings}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ecs:ScriptBindingViewModel">
                    <!-- Card is hidden under search only when neither the script title nor any override matches. -->
                    <StackPanel>
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static pg:AnyTrueConverter.Instance}">
                                <Binding Path="TitleMatchesFilter"/>
                                <Binding Path="#OverrideGrid.HasVisibleItems"/>
                            </MultiBinding>
                        </StackPanel.IsVisible>

                        <!-- A script binding is a section just like a component: the shared sectionHeader band
                             with the chevron pinned LEFT (before the icon/title) and the whole band collapsing
                             on click. The enable checkbox sits at the far right; as an interactive child it
                             swallows its own click, so ticking it never collapses the section. -->
                        <ToggleButton x:Name="ScriptToggle" Classes="sectionHeader" IsChecked="True">
                            <DockPanel>
                                <!-- Disclosure chevron on the LEFT, before the icon/title. -->
                                <Path DockPanel.Dock="Left" Classes="sectionChevron" Width="8" Height="8"
                                      Stretch="Uniform" Margin="2,0,8,0" VerticalAlignment="Center"
                                      Fill="{DynamicResource ThemeAccentSolidBrush}" Data="M 0,0 L 8,4 L 0,8 Z"/>
                                <!-- Remove (far right): detaches this script binding. Swallows its own click. -->
                                <Button DockPanel.Dock="Right" Padding="3" Margin="2,0,2,0"
                                        Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                                        Command="{Binding RemoveCommand}"
                                        ToolTip.Tip="Remove this script">
                                    <pg:IconView Width="13" Height="13" IconName="X"
                                                 Foreground="{DynamicResource ThemeMutedTextBrush}"/>
                                </Button>
                                <ToggleSwitch DockPanel.Dock="Right" Margin="6,0,4,0" VerticalAlignment="Center"
                                              IsChecked="{Binding Enabled}"
                                              OnContent="" OffContent="" MinHeight="0" Padding="0"
                                              ToolTip.Tip="Run this script"/>
                                <pg:IconView DockPanel.Dock="Left" Width="15" Height="15" Margin="0,0,6,0"
                                             VerticalAlignment="Center"
                                             IconName="{Binding Icon}" IconColor="{Binding IconColor}"/>
                                <TextBlock Text="{Binding Title}" FontWeight="Medium"
                                           Foreground="{DynamicResource ThemeAccentSolidBrush}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </ToggleButton>

                        <StackPanel IsVisible="{Binding #ScriptToggle.IsChecked}">
                            <pg:PropertyGridView x:Name="OverrideGrid" Embedded="True"
                                                 Items="{Binding Overrides}"
                                                 Filter="{Binding Filter}"/>
                            <!-- A script that exposes no editable properties still shows its header; this
                                 fills the empty body. -->
                            <TextBlock Text="This script has no editable properties." Margin="12,6"
                                       FontSize="{DynamicResource ThemeFontSizeSmall}" Opacity="0.5"
                                       IsVisible="{Binding !HasOverrides}"/>

                            <!-- Source: its own collapsible section band (like a category). The chevron sits
                                 LEFT; the hot-reload bolt + popout icon sit RIGHT and swallow their own
                                 clicks. Toggling it builds/tears down the editor, shown directly beneath.
                                 Only present when the script's C++ source was located. -->
                            <ToggleButton Classes="sectionHeader" IsVisible="{Binding HasSource}"
                                          IsChecked="{Binding IsSourceExpanded, Mode=TwoWay}">
                                <DockPanel>
                                    <Path DockPanel.Dock="Left" Classes="sectionChevron" Width="8" Height="8"
                                          Stretch="Uniform" Margin="2,0,8,0" VerticalAlignment="Center"
                                          Fill="{DynamicResource ThemeAccentSolidBrush}" Data="M 0,0 L 8,4 L 0,8 Z"/>
                                    <ToggleButton DockPanel.Dock="Right" Padding="4,2" Margin="4,0,4,0"
                                                  Background="Transparent" BorderThickness="0"
                                                  IsChecked="{Binding HotReload.Enabled, Mode=TwoWay}"
                                                  ToolTip.Tip="Hot reload this script on save">
                                        <pg:IconView Width="14" Height="14" IconName="Zap"
                                                     Foreground="{DynamicResource ThemeWarningBrush}"/>
                                    </ToggleButton>
                                    <Button DockPanel.Dock="Right" Command="{Binding PopOutCommand}"
                                            Padding="4,2" Background="Transparent" BorderThickness="0"
                                            ToolTip.Tip="Open this script in a dockable editor window">
                                        <pg:IconView Width="14" Height="14" IconName="ExternalLink"
                                                     Foreground="{DynamicResource ThemeInfoBrush}"/>
                                    </Button>
                                    <TextBlock Text="Source" FontWeight="Medium" VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThemeAccentSolidBrush}"/>
                                </DockPanel>
                            </ToggleButton>

                            <!-- The expanded source editor, hosted under its own card at a fixed working height
                                 so it scrolls with everything else. Collapsed to nothing until expanded. -->
                            <ContentControl Content="{Binding Inline}" Height="340" Margin="0,4,0,0"
                                            IsVisible="{Binding Inline, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                            <TextBlock IsVisible="{Binding SourceError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Text="{Binding SourceError}" Foreground="{DynamicResource ThemeErrorBrush}"
                                       FontSize="{DynamicResource ThemeFontSizeSmall}" Margin="12,4" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
