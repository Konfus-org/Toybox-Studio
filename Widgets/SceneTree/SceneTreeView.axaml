<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:services="using:Toybox.Studio.Services"
             xmlns:local="using:Toybox.Studio.Widgets.SceneTree"
             x:Class="Toybox.Studio.Widgets.SceneTree.SceneTreeView"
             x:DataType="local:SceneTreeViewModel">

    <suki:GlassCard Padding="8">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="4,0,4,8">
                <Button DockPanel.Dock="Right" Classes="Basic" Content="Refresh"
                        Command="{Binding RefreshCommand}"/>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Classes="h4" Text="Scene"/>
                    <TextBlock Text="{Binding Summary}" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>

            <TreeView ItemsSource="{Binding RootNodes}"
                      SelectedItem="{Binding SelectedNode}"
                      SelectionMode="Single">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="services:SceneNode">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>
    </suki:GlassCard>
</UserControl>
