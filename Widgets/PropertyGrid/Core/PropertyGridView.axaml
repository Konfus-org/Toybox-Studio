<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:ghost="using:Toybox.Studio.Widgets.Ghost"
             xmlns:behaviors="using:Toybox.Studio.Widgets.Behaviors.Animations"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.PropertyGridView"
             x:Name="Root">

    <UserControl.Resources>
        <!-- Shared chrome for every leaf row: resizable label gutter | state column | value well. -->
        <ControlTheme x:Key="{x:Type local:PropertyRow}" TargetType="local:PropertyRow">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <!-- Rows are flat (the card's surface shows through) and separated only by a pressed toy
                         groove: a faint dark hairline along the bottom with a 1px light highlight beneath it
                         (the crisp, blur-less BoxShadow). Nested rows add a faint warm depth tint on the inner
                         Grid so deeper levels read a touch deeper without a per-row gradient. -->
                    <Border x:Name="PART_RowRoot"
                            BorderBrush="{DynamicResource ThemeGrooveBrush}" BorderThickness="0,0,0,1"
                            BoxShadow="0 1 0 0 #2EFFFFFF"
                            Background="Transparent">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                            </Transitions>
                        </Border.Transitions>
                        <Grid Background="{TemplateBinding Depth,
                                          Converter={x:Static local:DepthToBrushConverter.Instance}}">
                            <Grid.ColumnDefinitions>
                                <!-- Auto + the shared size group defaults the label column to the widest header
                                     (so the longest name reads in full); the splitter then lets it be dragged
                                     down to a sliver. The row's parts render in two dynamic slots — Leading
                                     (inside the label gutter) and Trailing (after the value) — each an
                                     ItemsControl bound to the matching bucket on the view-model. -->
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PgLabel" MinWidth="20"/>   <!-- Label + leading parts -->
                                <ColumnDefinition Width="Auto"/>                                          <!-- resize splitter -->
                                <ColumnDefinition Width="*"/>                                             <!-- Value editor -->
                                <ColumnDefinition Width="Auto"/>                                          <!-- Trailing parts -->
                            </Grid.ColumnDefinitions>

                            <!-- Label gutter. A DockPanel (not a StackPanel) so the label is the fill child:
                                 that constrains its width to whatever the gutter has left, which is what makes
                                 CharacterEllipsis actually trigger. ClipToBounds backs it up so nothing ever
                                 spills into the value column when the splitter is dragged narrow. Depth is
                                 conveyed purely by the per-level shading on the inner Grid (no elbow), with a
                                 small indent so nested labels still tuck under their parent. -->
                            <Border Grid.Column="0" Background="Transparent"
                                    ClipToBounds="True">
                                <DockPanel LastChildFill="True" VerticalAlignment="Center"
                                           Margin="{TemplateBinding Depth,
                                                Converter={x:Static local:DepthToIndentConverter.Instance}}">
                                    <!-- Leading parts: the drag-to-reorder grip (list elements), tucked in just
                                         left of the disclosure gutter so a list-element row reads like a tree
                                         node. Empty (zero width) on a plain leaf. Each item's DataContext is its
                                         part, matched to its view by the PropertyPart DataTemplates below. -->
                                    <ItemsControl DockPanel.Dock="Left" VerticalAlignment="Stretch"
                                                  ItemsSource="{ReflectionBinding DataContext.LeadingParts, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <!-- Disclosure gutter: a fixed-width slot reserved on EVERY row. It holds the
                                         expand/collapse chevron on a composite row and stays empty (but still
                                         occupies its width) on a leaf, so the icon and label line up at the same x
                                         whether or not the row has children. The chevron hugs the gutter's left
                                         edge so it reads as a tight tree twisty. -->
                                    <ContentControl DockPanel.Dock="Left" Width="14" VerticalAlignment="Center"
                                                    HorizontalContentAlignment="Stretch"
                                                    Content="{ReflectionBinding DataContext.Disclosure, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <local:IconView DockPanel.Dock="Left" Width="15" Height="15"
                                                    Margin="4,0,6,0" VerticalAlignment="Center"
                                                    IconName="{TemplateBinding IconName}"
                                                    IconColor="{TemplateBinding IconColor}"/>
                                    <TextBlock x:Name="PART_Label" Text="{TemplateBinding HeaderText}"
                                               Margin="6,0,8,0" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource ThemeTextBrush}" Opacity="0.85"
                                               ToolTip.Tip="{TemplateBinding Description}"/>
                                </DockPanel>
                            </Border>

                            <!-- Drag handle: resizes the shared label column for every row at once. A visible
                                 hairline marks the column edge; the wider transparent splitter on top is the
                                 grab area (west-east cursor), and it brightens to the accent on hover/drag. -->
                            <Border Grid.Column="1" Width="1" HorizontalAlignment="Center"
                                    Background="{DynamicResource ThemeBorderBrush}" IsHitTestVisible="False"/>
                            <GridSplitter Grid.Column="1" Width="7" ResizeDirection="Columns"
                                          Cursor="SizeWestEast" Background="Transparent"/>

                            <!-- Value editor: the per-type widget hosted as the row's Content. -->
                            <Border Grid.Column="2" Padding="9,2,4,2">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"/>
                            </Border>

                            <!-- Trailing parts: the add/remove affordances and the state/reset indicator, on the
                                 right edge. Empty on a plain read-only leaf except for its state dot, so the
                                 indicator still sits immediately right of the value. -->
                            <ItemsControl Grid.Column="3" VerticalAlignment="Center"
                                          ItemsSource="{ReflectionBinding DataContext.TrailingParts, RelativeSource={RelativeSource TemplatedParent}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>

            <!-- Read-only rows gray their label. -->
            <Style Selector="^[IsReadOnly=true] /template/ TextBlock#PART_Label">
                <Setter Property="Opacity" Value="0.5"/>
            </Style>
            <!-- Hover paints the row's bottom groove in the primary accent — a moving underline as the pointer
                 travels the grid (eased by the BrushTransition on PART_RowRoot). -->
            <Style Selector="^:pointerover /template/ Border#PART_RowRoot">
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentSolidBrush}"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <!-- Compact, unified value-editor styling so every field reads as the same dark box. -->
    <UserControl.Styles>
        <!-- Every leaf property row animates in (a soft fade + scale-up pop) as a grid is built — the default
             entrance for any property view that doesn't supply its own. Intensity-scaled, off at 0. -->
        <Style Selector="local|PropertyRow">
            <Setter Property="behaviors:RowEntrance.Enabled" Value="True"/>
            <!-- Every row grows a hair on hover, like the buttons (composite rows additionally nod on
                 expand/collapse — wired per view via ExpandNod.State). -->
            <Setter Property="behaviors:Pop.Enabled" Value="True"/>
        </Style>
        <Style Selector="NumericUpDown.field">
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="SizeWestEast"/>
        </Style>
        <!-- Advertise drag-to-scrub: the inner text box shows the ↔ resize cursor on hover so the field
             reads as draggable, reverting to the I-beam only once it is focused for typing. -->
        <Style Selector="NumericUpDown.field /template/ TextBox#PART_TextBox">
            <Setter Property="Cursor" Value="SizeWestEast"/>
        </Style>
        <Style Selector="NumericUpDown.field:focus-within /template/ TextBox#PART_TextBox">
            <Setter Property="Cursor" Value="IBeam"/>
        </Style>
        <Style Selector="TextBox.field">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.field">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeWestEast"/>
        </Style>
        <!-- Input-field chrome shared by the non-text editors (handle picker, script link). Matches the toy
             well look of the TextBox/NumericUpDown fields: the recessed well fill plus an inset BoxShadow on
             the rounded border, so a picker reads as the same pressed-in control. -->
        <Style Selector="Border.fieldHost">
            <Setter Property="Background" Value="{DynamicResource ThemeWellFillBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
            <Setter Property="BoxShadow" Value="{DynamicResource ThemeWellInsetShadow}"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Chrome-less icon button used inside a field (e.g. the picker's browse button). -->
        <Style Selector="Button.fieldButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Opacity" Value="0.75"/>
        </Style>
        <Style Selector="Button.fieldButton:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.fieldButton /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- The reset affordance host: a chromeless button so the dot/lock indicator reads exactly as before
             but becomes clickable (revert to default) when the row supports it. No fill/shadow in any state —
             the dot itself just BRIGHTENS on hover (see the stateFilled/stateHollow hover rules below), no
             grey pill. -->
        <Style Selector="Button.resetIndicator">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="Button.resetIndicator /template/ ContentPresenter#PART_ContentPresenter,
                         Button.resetIndicator:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                         Button.resetIndicator:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Right-hand state indicators, produced by PropertyStateToIndicatorConverter. A value that differs
             from its default is a small flat accent dot (no shadow); a value at its default is an INSET crater
             pressed into the surface. Both BRIGHTEN on hover of the reset button rather than gaining a pill. -->
        <Style Selector="Border.stateFilled">
            <Setter Property="Width" Value="11"/>
            <Setter Property="Height" Value="11"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSolidBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.resetIndicator:pointerover Border.stateFilled">
            <Setter Property="Background" Value="{DynamicResource ThemeAccentBrightBrush}"/>
        </Style>
        <Style Selector="Button.resetIndicator:pointerover Border.stateHollow">
            <Setter Property="Background" Value="{DynamicResource ThemeSurfaceFlatBrush}"/>
        </Style>
        <!-- The at-default dot reads as a hollow RING: a surface-coloured fill carrying the inset crater (clay
             depth, when shadows are on) plus an explicit muted outline. The outline is the contrast guarantee —
             ThemeMutedTextBrush is auto-contrasted against the background, so the dot stays clearly visible on
             flat (shadow-less) themes where the crater alone would vanish into the surface. -->
        <Style Selector="Border.stateHollow">
            <Setter Property="Width" Value="11"/>
            <Setter Property="Height" Value="11"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource ThemeWellFillBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeMutedTextBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BoxShadow" Value="{DynamicResource ThemeWellInsetShadow}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="GridSplitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <!-- Each property group is a raised toy "pillow": the surface gradient, rounded, lifted off the panel
             by the card shadow (a dark cast + a light highlight). Rows and the header sit transparent on top,
             so the whole group reads as one moulded block. ClipToBounds keeps the rounded corners crisp; the
             card's own BoxShadow still renders outside the clip. -->
        <Style Selector="Border.toyCard">
            <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Margin" Value="2,0,2,10"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="BoxShadow" Value="{DynamicResource ThemeCardShadow}"/>
        </Style>
        <!-- Embedded grids (e.g. inside a component card) drop the card chrome so the host's card is the only
             one — no nested pillows. -->
        <Style Selector="Border.toyCard.flat">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <!-- Embedded grids drop the shadow-room padding so their rows align flush with the host card, but keep
             a right inset so the row's right-hand controls (state dot, list delete button) never sit under the
             host's overlay scrollbar. -->
        <Style Selector="StackPanel.flat">
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <!-- Collapsible section headers (category groups, nested object/array/theme parent rows) share the
             one ToggleButton.sectionHeader style defined in AppStyles, so every section reads identically. -->
    </UserControl.Styles>

    <!-- One template per property type; each hosts its own widget view. The single place a new
         widget gets wired into the grid (alongside PropertyViewModelFactory). -->
    <UserControl.DataTemplates>
        <DataTemplate DataType="local:NumberPropertyViewModel">
            <local:NumberPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:BoolPropertyViewModel">
            <local:BoolPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:StringPropertyViewModel">
            <local:StringPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:EnumPropertyViewModel">
            <local:EnumPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:VectorPropertyViewModel">
            <local:VectorPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:RotationPropertyViewModel">
            <local:RotationPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ColorPropertyViewModel">
            <local:ColorPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ObjectPropertyViewModel">
            <local:ObjectPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:MaterialInstancePropertyViewModel">
            <local:MaterialInstancePropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:MaterialOverridesViewModel">
            <local:MaterialOverridesView/>
        </DataTemplate>
        <DataTemplate DataType="local:MaterialSectionViewModel">
            <local:MaterialSectionView/>
        </DataTemplate>
        <DataTemplate DataType="local:MaterialSlotViewModel">
            <local:MaterialSlotView/>
        </DataTemplate>
        <DataTemplate DataType="local:ArrayPropertyViewModel">
            <local:ArrayPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:UnknownPropertyViewModel">
            <local:UnknownPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:HandlePickerPropertyViewModel">
            <local:HandlePickerPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:EntityPickerPropertyViewModel">
            <local:EntityPickerPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ScriptLinkPropertyViewModel">
            <local:ScriptLinkPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ThemePickerPropertyViewModel">
            <local:ThemePickerPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:SliderPropertyViewModel">
            <local:SliderPropertyView/>
        </DataTemplate>

        <!-- PropertyParts: the composable pieces a PropertyRow lays out in its slots. -->
        <DataTemplate DataType="local:StateIndicatorPart">
            <local:StateIndicatorPartView/>
        </DataTemplate>
        <DataTemplate DataType="local:DropdownPart">
            <local:DropdownPartView/>
        </DataTemplate>
        <DataTemplate DataType="local:ActionsPart">
            <local:ActionsPartView/>
        </DataTemplate>
        <DataTemplate DataType="local:HandlePart">
            <local:HandlePartView/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Panel>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <!-- One shared-size scope so every row's label column resizes together via the splitter. The
                 outer padding leaves room for the cards' shadows and keeps the right-hand controls clear of
                 the overlay scrollbar; embedded grids drop the card room but keep the right inset. -->
            <StackPanel Grid.IsSharedSizeScope="True" Margin="6,6,12,2"
                        Classes.flat="{Binding #Root.Embedded}">
                <ItemsControl ItemsSource="{Binding #Root.Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:PropertyCategoryGroup">
                            <Border Classes="toyCard" IsVisible="{Binding Visible}"
                                    Classes.flat="{Binding $parent[local:PropertyGridView].Embedded}">
                                <StackPanel>
                                    <StackPanel IsVisible="{Binding HasHeader}">
                                        <ToggleButton x:Name="CatToggle" Classes="sectionHeader" IsChecked="True">
                                            <DockPanel>
                                                <!-- The group's default-state indicator (and reset), like a composite
                                                     row: set when any child is, and reverting it resets every child.
                                                     A button so it swallows its own click — resetting never toggles
                                                     the category band. Pinned to the far-right edge to match the
                                                     leaf-row / section-header part order. -->
                                                <Border DockPanel.Dock="Right" Background="Transparent"
                                                        Margin="2,0,6,0" VerticalAlignment="Center"
                                                        ToolTip.Tip="{Binding Hint}">
                                                    <Button Classes="resetIndicator" Width="22"
                                                            Padding="0" VerticalAlignment="Center"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            Command="{Binding ResetCommand}"
                                                            IsHitTestVisible="{Binding IsResettable}"
                                                            Cursor="Hand"
                                                            Content="{Binding State,
                                                                Converter={x:Static local:PropertyStateToIndicatorConverter.Instance}}"/>
                                                </Border>
                                                <!-- Disclosure chevron on the LEFT, before the label, like a tree node. -->
                                                <Path DockPanel.Dock="Left" Classes="sectionChevron"
                                                      Width="8" Height="8" Stretch="Uniform" Margin="2,0,8,0"
                                                      VerticalAlignment="Center"
                                                      Fill="{DynamicResource ThemeAccentSolidBrush}"
                                                      Data="M 0,0 L 8,4 L 0,8 Z"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="12"
                                                           Foreground="{DynamicResource ThemeAccentSolidBrush}"/>
                                            </DockPanel>
                                        </ToggleButton>
                                        <ItemsControl ItemsSource="{Binding Items}"
                                                      IsVisible="{Binding #CatToggle.IsChecked}"/>
                                    </StackPanel>
                                    <ItemsControl IsVisible="{Binding !HasHeader}" ItemsSource="{Binding Items}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <ghost:GhostView Message="Nothing to show here yet." IsVisible="{Binding #Root.IsEmpty}"/>
    </Panel>
</UserControl>
