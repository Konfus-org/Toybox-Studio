<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =================================================================================================
         Toybox Studio's umbrella stylesheet. App.axaml includes only this file; it pulls in the focused
         style files under Shell/Styles/ in load order. Splitting keeps each control family in its own file
         while preserving a single include + a single, well-defined ordering:

           1. DesignTokens   — theme "variables" (first-frame fallbacks; ThemeApplier overwrites them live
                                from the active Theme.json). Must load first so everything below can key off
                                them via DynamicResource.
           2. Packaged themes — control themes we depend on (ColorPicker, Dock). Loaded after FluentTheme
                                (applied in App.axaml) and our tokens, before our overrides.
           3. Our control styles — window/shell chrome, buttons, inputs, menus, docking, tabs, sections.

         View-specific styles stay co-located in their own widget .axaml (Console, PropertyGrid, SearchBox,
         WorldTree, …) — only app-wide styling lives here.
         ================================================================================================= -->

    <StyleInclude Source="/Shell/Styles/DesignTokens.axaml"/>

    <!-- ColorPicker/ColorView templates ship in their own package and are NOT bundled with FluentTheme;
         without this include the ColorPicker control has no template (e.g. the Theme Creator's pickers). -->
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>
    <StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml"/>

    <StyleInclude Source="/Shell/Styles/WindowStyle.axaml"/>
    <StyleInclude Source="/Shell/Styles/ShellStyle.axaml"/>
    <StyleInclude Source="/Shell/Styles/ButtonStyle.axaml"/>
    <StyleInclude Source="/Shell/Styles/InputStyle.axaml"/>
    <StyleInclude Source="/Shell/Styles/MenuStyle.axaml"/>
    <StyleInclude Source="/Shell/Styles/DockStyle.axaml"/>
    <StyleInclude Source="/Shell/Styles/TabStyle.axaml"/>
    <StyleInclude Source="/Shell/Styles/SectionStyle.axaml"/>
</Styles>
