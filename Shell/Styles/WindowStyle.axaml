<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- WINDOW — app-wide window chrome + shared typography helpers. -->

    <!-- Apply the theme font, background, and text colour to every window. Foreground is inherited, so
         raw TextBlocks pick up the theme's Text colour unless they opt out. -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource ThemeFontSize}"/>
        <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
    </Style>

    <!-- Section header style. -->
    <Style Selector="TextBlock.h4">
        <Setter Property="FontSize" Value="{DynamicResource ThemeFontSizeLarge}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
</Styles>
