<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Toybox.Studio.Widgets.PropertyGrid"
             xmlns:ghost="using:Toybox.Studio.Widgets.Ghost"
             x:Class="Toybox.Studio.Widgets.PropertyGrid.PropertyGridView"
             x:Name="Root">

    <UserControl.Resources>
        <!-- Shared chrome for every leaf row: resizable label gutter | state column | value well. -->
        <ControlTheme x:Key="{x:Type local:PropertyRow}" TargetType="local:PropertyRow">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,0.5"
                            Background="{TemplateBinding Depth,
                                         Converter={x:Static local:DepthToBrushConverter.Instance}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PgLabel" MinWidth="64"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Label gutter. A DockPanel (not a StackPanel) so the label is the fill child:
                                 that constrains its width to whatever the gutter has left, which is what makes
                                 CharacterEllipsis actually trigger. ClipToBounds backs it up so nothing ever
                                 spills into the value column when the splitter is dragged narrow. -->
                            <Border Grid.Column="0" Background="{DynamicResource ThemeWellBrush}"
                                    ClipToBounds="True">
                                <DockPanel LastChildFill="True" VerticalAlignment="Center"
                                           Margin="{TemplateBinding Depth,
                                                Converter={x:Static local:DepthToIndentConverter.Instance}}">
                                    <!-- Nesting elbow first (connects the row to its parent's indent line),
                                         then this row's own disclosure chevron. Only on nested rows. -->
                                    <Border DockPanel.Dock="Left" Width="9" Height="8" Margin="2,0,0,0"
                                            VerticalAlignment="Center"
                                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                                            BorderThickness="1.5,0,0,1.5"
                                            IsVisible="{TemplateBinding Depth,
                                                Converter={x:Static local:PositiveIntConverter.Instance}}"/>
                                    <!-- Collapse chevron, shown only on parent (object/array) rows; the slot
                                         is always reserved so every label aligns. -->
                                    <Border DockPanel.Dock="Left" Width="15" VerticalAlignment="Center"
                                            Margin="2,0,0,0">
                                        <ToggleButton x:Name="PART_Chevron" Classes="rowChevron"
                                                      Width="15" Height="15" Padding="0"
                                                      IsVisible="{TemplateBinding IsParent}"
                                                      IsChecked="{Binding IsExpanded,
                                                          RelativeSource={RelativeSource TemplatedParent},
                                                          Mode=TwoWay}">
                                            <Path x:Name="PART_ChevronGlyph" Width="8" Height="8"
                                                  Stretch="Uniform" Fill="{DynamicResource ThemeTextBrush}"
                                                  Opacity="0.7" Data="M 0,0 L 4,4 L 0,8 Z"
                                                  RenderTransformOrigin="50%,50%"/>
                                        </ToggleButton>
                                    </Border>
                                    <local:IconView DockPanel.Dock="Left" Width="15" Height="15"
                                                    Margin="6,0,6,0" VerticalAlignment="Center"
                                                    IconName="{TemplateBinding IconName}"
                                                    IconColor="{TemplateBinding IconColor}"/>
                                    <TextBlock x:Name="PART_Label" Text="{TemplateBinding HeaderText}"
                                               Margin="6,0,8,0" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource ThemeTextBrush}" Opacity="0.85"
                                               ToolTip.Tip="{TemplateBinding Description}"/>
                                </DockPanel>
                            </Border>

                            <!-- Drag handle: resizes the shared label column for every row at once. The
                                 west-east cursor signals the edge is draggable on hover and while dragging. -->
                            <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                                          Cursor="SizeWestEast" Background="Transparent"/>

                            <!-- Value side: the editor, with a state indicator pinned to the right (no
                                 separator border, so the slot never reads as a resizable column edge). The
                                 row's PropertyState picks the control via PropertyStateToIndicatorConverter:
                                 lock = read-only, filled circle = non-default, hollow circle = at default. -->
                            <Border Grid.Column="2" Background="{DynamicResource ThemeWellBrush}">
                                <DockPanel>
                                    <ContentControl DockPanel.Dock="Right" Width="22" Margin="2,0,6,0"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Content="{ReflectionBinding State,
                                                        Converter={x:Static local:PropertyStateToIndicatorConverter.Instance}}"/>
                                    <Border Padding="9,2,4,2">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Stretch"/>
                                    </Border>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>

            <!-- Read-only rows gray their label. -->
            <Style Selector="^[IsReadOnly=true] /template/ TextBlock#PART_Label">
                <Setter Property="Opacity" Value="0.5"/>
            </Style>

            <!-- Strip the chevron ToggleButton's chrome (border/sizing). The ContentPresenter background
                 in each interaction state can't be reached from here — a nested style inside a ControlTheme
                 may cross only one template boundary — so that lives in UserControl.Styles below, keyed off
                 the rowChevron class (same pattern as categoryHeader). -->
            <Style Selector="^ /template/ ToggleButton#PART_Chevron">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
            </Style>
            <!-- Glyph points right when collapsed, down when expanded. -->
            <Style Selector="^ /template/ ToggleButton#PART_Chevron:checked Path#PART_ChevronGlyph">
                <Setter Property="RenderTransform">
                    <RotateTransform Angle="90"/>
                </Setter>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <!-- Compact, unified value-editor styling so every field reads as the same dark box. -->
    <UserControl.Styles>
        <Style Selector="NumericUpDown.field">
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="TextBox.field">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.field">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeWestEast"/>
        </Style>
        <!-- Input-field chrome shared by the non-text editors (handle picker, script link). Mirrors the
             FluentTheme TextBox resources exactly (same background, border brush, thickness, corner radius
             and height) so a picker reads as the same boxed control as the TextBox/NumericUpDown fields. -->
        <Style Selector="Border.fieldHost">
            <Setter Property="Background" Value="{DynamicResource TextControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="{DynamicResource TextControlBorderThemeThickness}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.fieldHost:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushPointerOver}"/>
            <Setter Property="Background" Value="{DynamicResource TextControlBackgroundPointerOver}"/>
        </Style>
        <!-- Chrome-less icon button used inside a field (e.g. the picker's browse button). -->
        <Style Selector="Button.fieldButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Opacity" Value="0.75"/>
        </Style>
        <Style Selector="Button.fieldButton:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.fieldButton /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Right-hand state indicators, produced by PropertyStateToIndicatorConverter. -->
        <Style Selector="Ellipse.stateFilled">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="Fill" Value="{DynamicResource ThemeTextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Ellipse.stateHollow">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="StrokeThickness" Value="1.2"/>
            <Setter Property="Stroke" Value="{DynamicResource ThemeTextBrush}"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="GridSplitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <!-- Collapsible category band: lighter than the component header, sits above its rows. -->
        <Style Selector="ToggleButton.categoryHeader">
            <Setter Property="Background" Value="{DynamicResource ThemeBandBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0.5,0,0.5"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ToggleButton.categoryHeader /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.categoryHeader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ThemeBandBrush}"/>
        </Style>
        <Style Selector="ToggleButton.categoryHeader:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.categoryHeader:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Row collapse chevron: keep its ContentPresenter transparent in every state so FluentTheme's
             accent fill never shows. Single template hop from the class selector (a nested style inside the
             PropertyRow ControlTheme can't cross two template boundaries to reach this). -->
        <Style Selector="ToggleButton.rowChevron /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.rowChevron:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.rowChevron:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.rowChevron:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.categoryHeader Path.catChevron">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        </Style>
        <Style Selector="ToggleButton.categoryHeader:checked Path.catChevron">
            <Setter Property="RenderTransform">
                <RotateTransform Angle="90"/>
            </Setter>
        </Style>
    </UserControl.Styles>

    <!-- One template per property type; each hosts its own widget view. The single place a new
         widget gets wired into the grid (alongside PropertyViewModelFactory). -->
    <UserControl.DataTemplates>
        <DataTemplate DataType="local:IntPropertyViewModel">
            <local:IntPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:FloatPropertyViewModel">
            <local:FloatPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:BoolPropertyViewModel">
            <local:BoolPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:StringPropertyViewModel">
            <local:StringPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:EnumPropertyViewModel">
            <local:EnumPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:VectorPropertyViewModel">
            <local:VectorPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:RotationPropertyViewModel">
            <local:RotationPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ColorPropertyViewModel">
            <local:ColorPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ObjectPropertyViewModel">
            <local:ObjectPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ArrayPropertyViewModel">
            <local:ArrayPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:UnknownPropertyViewModel">
            <local:UnknownPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:HandlePickerPropertyViewModel">
            <local:HandlePickerPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:EntityPickerPropertyViewModel">
            <local:EntityPickerPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ScriptLinkPropertyViewModel">
            <local:ScriptLinkPropertyView/>
        </DataTemplate>
        <DataTemplate DataType="local:ThemePickerPropertyViewModel">
            <local:ThemePickerPropertyView/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Panel>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <!-- One shared-size scope so every row's label column resizes together via the splitter. -->
            <StackPanel Grid.IsSharedSizeScope="True">
                <ItemsControl ItemsSource="{Binding #Root.Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:PropertyCategoryGroup">
                            <StackPanel IsVisible="{Binding Visible}">
                                <StackPanel IsVisible="{Binding HasHeader}">
                                    <ToggleButton x:Name="CatToggle" Classes="categoryHeader" IsChecked="True">
                                        <DockPanel>
                                            <Path DockPanel.Dock="Left" Classes="catChevron" Width="8" Height="8"
                                                  Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"
                                                  Fill="{DynamicResource ThemeTextBrush}"
                                                  Data="M 0,0 L 4,4 L 0,8 Z"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="11"
                                                       Opacity="0.7"/>
                                        </DockPanel>
                                    </ToggleButton>
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  IsVisible="{Binding #CatToggle.IsChecked}"/>
                                </StackPanel>
                                <ItemsControl IsVisible="{Binding !HasHeader}" ItemsSource="{Binding Items}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <ghost:GhostView Message="Nothing to show here yet." IsVisible="{Binding #Root.IsEmpty}"/>
    </Panel>
</UserControl>
