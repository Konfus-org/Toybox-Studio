<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:console="using:Toybox.Studio.Widgets.Console"
             xmlns:local="using:Toybox.Studio.Widgets.LogConsole"
             x:Class="Toybox.Studio.Widgets.LogConsole.LogConsoleView"
             x:DataType="local:LogConsoleViewModel">
    <console:ConsoleView DataContext="{Binding Console}"/>
</UserControl>
